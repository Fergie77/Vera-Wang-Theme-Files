  <script>
(function () {
  function $ov() { return document.querySelector('[data-cart-overlay]'); }
  function $pn() { return document.querySelector('[data-cart-panel]'); }
  function $bd() { return document.querySelector('[data-cart-close].mini-cart-v2_backdrop'); } // &larr; new
  function openCart() {
    var ov = $ov(), pn = $pn(), bd = $bd();
    if (ov) ov.classList.add('is-open');
    if (pn) pn.classList.add('is-open');
    if (bd) bd.classList.add('is-open');                                                       // &larr; new
    document.body.setAttribute('data-cart-open', 'true');
    window.dispatchEvent(new CustomEvent('cartupdated'));
  }
  function closeCart() {
    var ov = $ov(), pn = $pn(), bd = $bd();
    if (ov) ov.classList.remove('is-open');
    if (pn) pn.classList.remove('is-open');
    if (bd) bd.classList.remove('is-open');                                                    // &larr; new
    document.body.removeAttribute('data-cart-open');
  }
  document.addEventListener('click', function (e) {
    if (e.target.closest('[data-cart-toggle]')) { e.preventDefault(); openCart(); return; }
    if (!document.body.hasAttribute('data-cart-open')) return;
    if (e.target.closest('[data-cart-close]') || e.target.closest('.nav_dropdown-close-button')) {
      e.preventDefault();
      closeCart();
    }
  });
  document.addEventListener('keydown', function (e) {
    if (e.key === 'Escape') closeCart();
  });
  window.addEventListener('toggleminicart', openCart);
})();
</script>
  <script>
//Wishlist JS Amends
(function () {
  'use strict';
  function upsizeImage(img) {
    if (!img || img.dataset.upsized) return;
    img.dataset.upsized = '1';
    var src = img.getAttribute('src') || '';
    if (src.includes('cdn.shopify.com'))
      img.setAttribute('src', src.replace(/width=\d+/, 'width=600'));
  }
  function upsizeWishlistImages() {
    document.querySelectorAll('.nm-wishlist-item-image').forEach(upsizeImage);
  }
  function initWishlistCards() {
    document.querySelectorAll('.nm-wishlist-item-card').forEach(function (card) {
      if (card.dataset.wlInit) return;
      card.dataset.wlInit = '1';
      var img = card.querySelector('.nm-wishlist-item-image');
      if (img) { upsizeImage(img); img.style.cssText = ''; }
      var titleCol = document.createElement('div');
      titleCol.className = 'nm-wishlist-item-title-col';
      var titleLink = card.querySelector('a.nm-wishlist-item-title, a[class*="title"]') || card.querySelector('a');
      var variantEl = card.querySelector('.nm-wishlist-item-variant, [class*="variant"]');
      var priceEl   = card.querySelector('.nm-wishlist-item-price, [class*="price"]');
      var removeBtn = card.querySelector('button.nm-wishlist-item-remove-button, [class*="remove"]');
      if (titleLink) titleCol.appendChild(titleLink);
      if (variantEl) titleCol.appendChild(variantEl);
      if (priceEl)   titleCol.appendChild(priceEl);
      if (removeBtn) {
        var textRemove = document.createElement('button');
        textRemove.className = 'nm-wishlist-item-remove-btn';
        textRemove.textContent = 'Remove';
        textRemove.addEventListener('click', function () { removeBtn.click(); });
        titleCol.appendChild(textRemove);
        removeBtn.style.display = 'none';
      }
      var row = card.querySelector('div:first-child') || document.createElement('div');
      row.innerHTML = '';
      if (img) row.appendChild(img);
      row.appendChild(titleCol);
      var atcBtn = card.querySelector('.nm-wishlist-item-add-to-cart-button, button[class*="add-to-cart"]');
      if (atcBtn) { atcBtn.className = 'nm-wishlist-item-add-to-cart-button'; card.appendChild(atcBtn); }
    });
  }
  function replaceCloseButtons() {
    var header = document.querySelector('.nm-wishlist-drawer-header');
    if (!header) return;
    var btn = header.querySelector('.nm-modal-close-button');
    if (btn && btn.textContent.trim() !== 'Close') btn.innerHTML = 'Close';
  }
  if (!window._wlFetchPatched) {
    window._wlFetchPatched = true;
    var _fetch = window.fetch;
    window.fetch = function (input, init) {
      var url = typeof input === 'string' ? input : (input && input.url) || '';
      var result = _fetch.apply(this, arguments);
      if (url.includes('/cart/add'))
        result.then(function (r) { if (r.ok) document.dispatchEvent(new CustomEvent('carttotalitems')); }).catch(function(){});
      return result;
    };
  }
  function isMobile() { return window.innerWidth <= 767; }
  function getDrawerContainer() {
    return document.querySelector('.nm-modal-container:has(.nm-wishlist-drawer)');
  }
  function getLoginContainer() {
    return document.querySelector('.nm-modal-container:has(.nm-wishlist-login-modal)');
  }
  function positionWrapper() {
    var drawer = document.querySelector('.nm-wishlist-drawer');
    if (!drawer) return;
    /* *** KEY FIX: the app positions the PARENT wrapper div, not the drawer itself ***
       Override both the parent wrapper AND the drawer to take full-width bottom position */
    var wrapper = drawer.parentElement;
    if (wrapper && wrapper !== document.querySelector('.nm-modal-container')) {
      wrapper.style.setProperty('position',   'fixed',  'important');
      wrapper.style.setProperty('left',       '0',      'important');
      wrapper.style.setProperty('right',      '0',      'important');
      wrapper.style.setProperty('bottom',     '0',      'important');
      wrapper.style.setProperty('top',        'auto',   'important');
      wrapper.style.setProperty('width',      '100%',   'important');
      wrapper.style.setProperty('max-width',  '100%',   'important');
      wrapper.style.setProperty('transform',  'none',   'important');
      wrapper.style.setProperty('z-index',    '2002',   'important');
    }
    drawer.style.setProperty('position',   'fixed',  'important');
    drawer.style.setProperty('bottom',     '0',      'important');
    drawer.style.setProperty('left',       '0',      'important');
    drawer.style.setProperty('right',      '0',      'important');
    drawer.style.setProperty('width',      '100%',   'important');
    drawer.style.setProperty('max-height', '92dvh',  'important');
    drawer.style.setProperty('z-index',    '2002',   'important');
  }
  function doOpen() {
    if (!isMobile()) return;
    var container = getDrawerContainer();
    var drawer    = document.querySelector('.nm-wishlist-drawer');
    if (!container || !drawer) return;
    container.style.setProperty('opacity', '1', 'important');
    container.style.setProperty('pointer-events', 'all', 'important');
    positionWrapper();
    drawer.style.setProperty('transform',  'translateY(100%)', 'important');
    drawer.style.setProperty('transition', 'none',             'important');
    requestAnimationFrame(function () {
      requestAnimationFrame(function () {
        drawer.style.setProperty('transition', 'transform 0.4s ease', 'important');
        drawer.style.setProperty('transform',  'translateY(0)',        'important');
      });
    });
    startLoginModalPoller();
  }
  function doClose() {
    if (!isMobile()) return;
    var container = getDrawerContainer();
    var drawer    = document.querySelector('.nm-wishlist-drawer');
    if (!container || !drawer) return;
    drawer.style.setProperty('transition', 'transform 0.4s ease', 'important');
    drawer.style.setProperty('transform',  'translateY(100%)',     'important');
    setTimeout(function () {
      container.style.removeProperty('opacity');
      container.style.removeProperty('pointer-events');
    }, 420);
  }
  /* --- Login modal: appear centred, close button works --- */
  var loginPollerTimer = null;
  function startLoginModalPoller() {
    if (loginPollerTimer) return;
    var attempts = 0;
    loginPollerTimer = setInterval(function () {
      attempts++;
      var lc = getLoginContainer();
      if (lc) {
        var aw = lc.children[1]; /* anonymous wrapper inside login container */
        if (aw) {
          var awStyle = aw.getAttribute('style') || '';
          if (awStyle.includes('translate(-50%, 100%)')) {
            aw.setAttribute('style', awStyle.replace('translate(-50%, 100%)', 'translate(-50%, -50%)'));
            lc.style.removeProperty('display');
            patchLoginModalClose(lc);
            clearInterval(loginPollerTimer);
            loginPollerTimer = null;
            return;
          }
        }
      }
      if (attempts > 50) {
        clearInterval(loginPollerTimer);
        loginPollerTimer = null;
      }
    }, 100);
  }
  function patchLoginModalClose(lc) {
    var closeBtn = lc ? lc.querySelector('.nm-modal-close-button') : null;
    if (!closeBtn || closeBtn.dataset.wlLoginClose) return;
    closeBtn.dataset.wlLoginClose = '1';
    closeBtn.addEventListener('click', function () {
      lc.style.setProperty('display', 'none', 'important');
      setTimeout(function () { lc.style.removeProperty('display'); }, 500);
    }, false);
  }
  /* --- Body wrapper padding fix --- */
  function fixBodyWrapperPadding() {
    var drawer = document.querySelector('.nm-wishlist-drawer');
    if (!drawer) return;
    Array.from(drawer.children).forEach(function (child) {
      var cls = (typeof child.className === 'string') ? child.className : '';
      if (cls !== 'nm-wishlist-drawer-header') {
        child.style.setProperty('padding-left',  '0', 'important');
        child.style.setProperty('padding-right', '0', 'important');
        child.style.setProperty('padding-top',   '0', 'important');
      }
    });
  }
  /* --- Button patching --- */
  function patchWishlistButtons() {
    var header = document.querySelector('.nm-wishlist-drawer-header');
    if (header && !header.dataset.wlPatched) {
      header.dataset.wlPatched = '1';
      var closeBtn = header.querySelector('.nm-modal-close-button');
      if (closeBtn) {
        closeBtn.addEventListener('click', function (e) {
          e.stopImmediatePropagation();
          doClose();
          setTimeout(function () {
            closeBtn.dispatchEvent(new MouseEvent('click', { bubbles: false }));
          }, 10);
        }, true);
      }
    }
    document.querySelectorAll('.nm-wishlist-inline-access-button, [class*="wishlist-access"]')
      .forEach(function (btn) {
        if (btn.dataset.wlOpenPatched) return;
        btn.dataset.wlOpenPatched = '1';
        btn.addEventListener('click', function () { setTimeout(doOpen, 10); });
      });
  }
  /* --- MutationObserver --- */
  var observer = new MutationObserver(function () {
    initWishlistCards();
    replaceCloseButtons();
    upsizeWishlistImages();
    fixBodyWrapperPadding();
    patchWishlistButtons();
  });
  observer.observe(document.body, { childList: true, subtree: true });
  initWishlistCards();
  replaceCloseButtons();
  upsizeWishlistImages();
  fixBodyWrapperPadding();
  patchWishlistButtons();
})();
</script>
