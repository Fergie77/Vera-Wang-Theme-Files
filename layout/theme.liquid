  {% render 'search_javascript' %}
  <script>
(function () {
  function $ov() { return document.querySelector('[data-cart-overlay]'); }
  function $pn() { return document.querySelector('[data-cart-panel]'); }
  function openCart() {
    var ov = $ov(), pn = $pn();
    if (ov) ov.classList.add('is-open');
    if (pn) pn.classList.add('is-open');
    document.body.setAttribute('data-cart-open', 'true');
    window.dispatchEvent(new CustomEvent('cartupdated'));
  }
  function closeCart() {
    var ov = $ov(), pn = $pn();
    if (ov) ov.classList.remove('is-open');
    if (pn) pn.classList.remove('is-open');
    document.body.removeAttribute('data-cart-open');
  }
  document.addEventListener('click', function (e) {
    if (e.target.closest('[data-cart-toggle]')) { e.preventDefault(); openCart(); return; }
    if (!document.body.hasAttribute('data-cart-open')) return;
    if (e.target.closest('[data-cart-close]') || e.target.closest('.nav_dropdown-close-button')) {
      e.preventDefault();
      closeCart();
    }
  });
  document.addEventListener('keydown', function (e) {
    if (e.key === 'Escape') closeCart();
  });
  window.addEventListener('toggleminicart', openCart);
})();
</script>
  <script>
const el = document.querySelector('.product_list-wrapper');
const wrapper = el.querySelector('.w-dyn-items');
const mq = window.matchMedia('(max-width: 776px)');
let swiper;
function initSwiper() {
  if (mq.matches && !swiper) {
    el.classList.add('swiper');
    wrapper.classList.add('swiper-wrapper');
    swiper = new Swiper(el, {
      slidesPerView: 1.2,
      spaceBetween: 16,
      grabCursor: true,
      mousewheel: { forceToAxis: true },
    });
  } else if (!mq.matches && swiper) {
    swiper.destroy(true, true);
    swiper = null;
    el.classList.remove('swiper');
    wrapper.classList.remove('swiper-wrapper');
  }
}
mq.addEventListener('change', initSwiper);
initSwiper();
</script>
<script id="wl-js">
/* Goodcraft wishlist drawer — mobile bottom-sheet override.
   Mobile only (≤767px). Desktop keeps Goodcraft default (right-side panel).
   See the brief in the PR description for the why behind each step. */
(function () {
  var MQ_QUERY = '(max-width: 767px)';
  if (!window.matchMedia(MQ_QUERY).matches) return;

  var SLIDE_TRANSITION = 'transform 0.35s cubic-bezier(0.32,0.72,0,1)';
  var _cssPatched = false;
  var _scheduled = false;

  /* Goodcraft injects its own <style> into the portal <div>. We can't beat its
     !important rules from theme CSS (loaded earlier), so we mutate the rules
     in-place via CSSOM. */
  function patchGoodcraftPortalCSS() {
    if (_cssPatched) return;
    var styles = document.querySelectorAll('style');
    var patchedSomething = false;
    styles.forEach(function (s) {
      if (!s.parentElement || s.parentElement.tagName !== 'DIV') return;
      var sheet = s.sheet;
      if (!sheet) return;
      var rules;
      try { rules = sheet.cssRules; } catch (e) { return; }
      for (var i = 0; i < rules.length; i++) {
        var r = rules[i];
        if (r.selectorText && r.selectorText.indexOf('.nm-wishlist-item-card') !== -1) {
          r.style.setProperty('gap', '12px', 'important');
          patchedSomething = true;
        }
        if (r.cssRules && r.media) {
          for (var j = 0; j < r.cssRules.length; j++) {
            var inner = r.cssRules[j];
            if (!inner.selectorText) continue;
            if (inner.selectorText.indexOf('.nm-wishlist-summery') !== -1) {
              inner.style.removeProperty('border-bottom');
              inner.style.removeProperty('border');
              patchedSomething = true;
            }
            if (inner.selectorText.indexOf('.nm-wishlist-item-card') !== -1) {
              inner.style.setProperty('gap', '12px', 'important');
              patchedSomething = true;
            }
          }
        }
      }
    });
    if (patchedSomething) _cssPatched = true;
  }

  function positionWrapperForMobile(wrapper) {
    if (!wrapper) return;
    wrapper.style.setProperty('position', 'absolute', 'important');
    wrapper.style.setProperty('bottom', '0', 'important');
    wrapper.style.setProperty('left', '0', 'important');
    wrapper.style.setProperty('right', '0', 'important');
    wrapper.style.setProperty('top', 'auto', 'important');
    wrapper.style.setProperty('width', '100%', 'important');
    wrapper.style.setProperty('max-width', '100%', 'important');
    wrapper.style.setProperty('height', 'auto', 'important');
    /* Goodcraft sets height:100% inline on the drawer body — strip it so the
       drawer collapses to content height on mobile. */
    var drawer = wrapper.querySelector('.nm-wishlist-drawer');
    if (drawer && drawer.children[1] && drawer.children[1].style && drawer.children[1].style.height) {
      drawer.children[1].style.removeProperty('height');
    }
  }

  function slideIn(wrapper) {
    if (!wrapper) return;
    positionWrapperForMobile(wrapper);
    wrapper.style.setProperty('transition', SLIDE_TRANSITION, 'important');
    wrapper.style.setProperty('transform', 'translateY(0%)', 'important');
  }
  function slideOut(wrapper) {
    if (!wrapper) return;
    wrapper.style.setProperty('transition', SLIDE_TRANSITION, 'important');
    wrapper.style.setProperty('transform', 'translateY(110%)', 'important');
  }
  function snapToBottom(wrapper) {
    if (!wrapper) return;
    positionWrapperForMobile(wrapper);
    wrapper.style.setProperty('transition', 'none', 'important');
    wrapper.style.setProperty('transform', 'translateY(110%)', 'important');
  }

  function attachContainerWatcher() {
    var container = document.querySelector('.nm-modal-container');
    if (!container || container._wlWatched) return;
    var wrapper = container.querySelector(':scope > div');
    if (!wrapper) return;
    container._wlWatched = true;

    var isOpen = false;
    snapToBottom(wrapper);

    /* Observer 1: container [style] — Alpine sets opacity:1/0 on open/close. */
    new MutationObserver(function () {
      var op = container.style.opacity;
      var pe = container.style.pointerEvents;
      var nowOpen = op === '1' || pe === 'auto';
      if (nowOpen && !isOpen) {
        isOpen = true;
        slideIn(wrapper);
      } else if (!nowOpen && isOpen) {
        isOpen = false;
        slideOut(wrapper);
      }
    }).observe(container, { attributes: true, attributeFilter: ['style'] });

    /* Observer 2: wrapper [style] — Alpine writes translateX(...) on open;
       we override with translateY immediately. */
    new MutationObserver(function () {
      var t = wrapper.style.transform || '';
      if (t.indexOf('translateX') !== -1) {
        if (isOpen) slideIn(wrapper); else snapToBottom(wrapper);
      }
    }).observe(wrapper, { attributes: true, attributeFilter: ['style'] });
  }

  function addRemoveButtons() {
    var cards = document.querySelectorAll('.nm-wishlist-item-card');
    cards.forEach(function (card) {
      if (card.querySelector('.nm-wl-remove-text-btn')) return;
      var title = card.querySelector('.nm-wishlist-item-title');
      var iconBtn = card.querySelector('.nm-wishlist-item-remove-button');
      if (!title || !iconBtn) return;
      var btn = document.createElement('button');
      btn.className = 'nm-wl-remove-text-btn';
      btn.type = 'button';
      btn.textContent = 'REMOVE';
      btn.addEventListener('click', function (e) {
        e.preventDefault();
        iconBtn.click();
      });
      title.appendChild(btn);
    });
  }

  function upsizeImages() {
    var imgs = document.querySelectorAll('.nm-wishlist-item-image');
    imgs.forEach(function (img) {
      var src = img.getAttribute('src');
      if (!src || src.indexOf('width=600') !== -1) return;
      var next = src.replace(/width=\d+/g, 'width=600');
      if (next !== src) img.setAttribute('src', next);
    });
  }

  /* Cart count sync — when Goodcraft adds to cart, re-broadcast totals so the
     theme's mini-cart count updates. */
  if (!window._wlFetchPatched) {
    window._wlFetchPatched = true;
    var origFetch = window.fetch;
    window.fetch = function () {
      var args = arguments;
      var p = origFetch.apply(this, args);
      try {
        var url = args[0] && (args[0].url || args[0]);
        if (typeof url === 'string' && /\/cart\/add(\.js)?(\?|$)/.test(url)) {
          p.then(function () {
            origFetch('/cart.js')
              .then(function (r) { return r.json(); })
              .then(function (data) {
                window.dispatchEvent(new CustomEvent('carttotalitems', { detail: data }));
              })
              .catch(function () {});
          });
        }
      } catch (e) {}
      return p;
    };
  }

  function run() {
    patchGoodcraftPortalCSS();
    attachContainerWatcher();
    addRemoveButtons();
    upsizeImages();
  }

  function schedule() {
    if (_scheduled) return;
    _scheduled = true;
    requestAnimationFrame(function () { _scheduled = false; run(); });
  }

  new MutationObserver(schedule).observe(document.body, { childList: true, subtree: true });
  run();
})();
</script>
