  <script>
(function () {
  function $ov() { return document.querySelector('[data-cart-overlay]'); }
  function $pn() { return document.querySelector('[data-cart-panel]'); }
  function $bd() { return document.querySelector('[data-cart-close].mini-cart-v2_backdrop'); } // &larr; new
  function openCart() {
    var ov = $ov(), pn = $pn(), bd = $bd();
    if (ov) ov.classList.add('is-open');
    if (pn) pn.classList.add('is-open');
    if (bd) bd.classList.add('is-open');                                                       // &larr; new
    document.body.setAttribute('data-cart-open', 'true');
    window.dispatchEvent(new CustomEvent('cartupdated'));
  }
  function closeCart() {
    var ov = $ov(), pn = $pn(), bd = $bd();
    if (ov) ov.classList.remove('is-open');
    if (pn) pn.classList.remove('is-open');
    if (bd) bd.classList.remove('is-open');                                                    // &larr; new
    document.body.removeAttribute('data-cart-open');
  }
  document.addEventListener('click', function (e) {
    if (e.target.closest('[data-cart-toggle]')) { e.preventDefault(); openCart(); return; }
    if (!document.body.hasAttribute('data-cart-open')) return;
    if (e.target.closest('[data-cart-close]') || e.target.closest('.nav_dropdown-close-button')) {
      e.preventDefault();
      closeCart();
    }
  });
  document.addEventListener('keydown', function (e) {
    if (e.key === 'Escape') closeCart();
  });
  window.addEventListener('toggleminicart', openCart);
})();
</script>
<script>
(function () {
  'use strict';
  if (window._wlv4) return;
  window._wlv4 = true;

  var TRANS = 'transform 0.35s cubic-bezier(0.32,0.72,0,1)';

  /* Fix Goodcraft's portal-injected <style> tag */
  function patchGoodcraftPortalCSS() {
    document.querySelectorAll('style').forEach(function (styleEl) {
      if (!styleEl.parentElement || styleEl.parentElement.tagName !== 'DIV') return;
      try {
        var rules = Array.from(styleEl.sheet.cssRules || []);
        rules.forEach(function (r) {
          if (r.selectorText === '.nm-wishlist-item-card' &&
              r.style.getPropertyPriority('gap') === 'important') {
            r.style.setProperty('gap', '12px', 'important');
          }
          if (r.cssRules) {
            Array.from(r.cssRules).forEach(function (inner) {
              if (inner.selectorText === '.nm-wishlist-summery') {
                inner.style.removeProperty('border-bottom');
              }
            });
          }
        });
      } catch (e) {}
    });
  }

  /* Set wrapper to bottom-anchored mobile layout */
  function positionWrapperForMobile(w) {
    w.style.setProperty('position', 'absolute', 'important');
    w.style.setProperty('bottom', '0', 'important');
    w.style.setProperty('left', '0', 'important');
    w.style.setProperty('right', '0', 'important');
    w.style.setProperty('top', 'auto', 'important');
    w.style.setProperty('width', '100%', 'important');
    w.style.setProperty('max-width', '100%', 'important');
    w.style.setProperty('height', 'auto', 'important');
    var drawer = w.querySelector('.nm-wishlist-drawer');
    if (drawer) {
      Array.from(drawer.children).forEach(function (child) {
        if (child.style && child.style.height === '100%') {
          child.style.removeProperty('height');
        }
      });
    }
  }

  function slideIn(w) {
    positionWrapperForMobile(w);
    w.style.setProperty('transition', TRANS, 'important');
    w.style.setProperty('transform', 'translateY(0%)', 'important');
  }

  function slideOut(w) {
    w.style.setProperty('transition', TRANS, 'important');
    w.style.setProperty('transform', 'translateY(110%)', 'important');
  }

  function snapToBottom(w) {
    positionWrapperForMobile(w);
    w.style.setProperty('transition', 'none', 'important');
    w.style.setProperty('transform', 'translateY(110%)', 'important');
  }

  /* Watch container AND wrapper — dual observer */
  function attachContainerWatcher() {
    var container = document.querySelector('.nm-modal-container');
    if (!container || container._wlWatched) return;
    container._wlWatched = true;

    function isMobile() { return window.innerWidth <= 767; }

    var w = container.firstElementChild;
    if (w && isMobile()) snapToBottom(w);

    var isOpen = false;

    /* Observer 1: container opacity → drive open/close */
    new MutationObserver(function () {
      if (!isMobile()) return;
      var w2 = container.firstElementChild;
      if (!w2) return;
      var st = container.getAttribute('style') || '';
      if (st.indexOf('opacity: 1') !== -1 || st.indexOf('opacity:1') !== -1) {
        isOpen = true;
        slideIn(w2);
      } else if (st.indexOf('opacity: 0') !== -1 || st.indexOf('opacity:0') !== -1) {
        isOpen = false;
        slideOut(w2);
      }
    }).observe(container, { attributes: true, attributeFilter: ['style'] });

    /* Observer 2: wrapper style — intercept any translateX Goodcraft writes */
    if (w) {
      new MutationObserver(function () {
        if (!isMobile()) return;
        var w2 = container.firstElementChild;
        if (!w2) return;
        var wStyle = w2.getAttribute('style') || '';
        if (wStyle.indexOf('translateX') !== -1) {
          /* Goodcraft wrote translateX — override immediately */
          if (isOpen) {
            slideIn(w2);
          } else {
            positionWrapperForMobile(w2);
            w2.style.setProperty('transition', 'none', 'important');
            w2.style.setProperty('transform', 'translateY(110%)', 'important');
          }
        }
      }).observe(w, { attributes: true, attributeFilter: ['style'] });
    }
  }

  /* Inject text REMOVE button */
  function addRemoveButtons() {
    document.querySelectorAll('.nm-wishlist-item-card').forEach(function (card) {
      if (card.querySelector('.nm-wl-remove-text-btn')) return;
      var titleDiv = card.querySelector('.nm-wishlist-item-title');
      var iconBtn  = card.querySelector('.nm-wishlist-item-remove-button');
      if (!titleDiv || !iconBtn) return;
      var textBtn = document.createElement('button');
      textBtn.className   = 'nm-wl-remove-text-btn';
      textBtn.textContent = 'REMOVE';
      textBtn.type        = 'button';
      textBtn.addEventListener('click', function (e) {
        e.preventDefault();
        e.stopPropagation();
        iconBtn.click();
      });
      titleDiv.appendChild(textBtn);
    });
  }

  /* Upsize images */
  function upsizeImages() {
    document.querySelectorAll('.nm-wishlist-item-image').forEach(function (img) {
      if (img.src && img.src.indexOf('cdn.shopify.com') !== -1 &&
          img.src.indexOf('width=600') === -1) {
        img.src = img.src.replace(/width=\d+/, 'width=600');
      }
    });
  }

  /* Cart count sync */
  if (!window._wlFetchPatched) {
    window._wlFetchPatched = true;
    var _origFetch = window.fetch;
    window.fetch = function () {
      var args = Array.prototype.slice.call(arguments);
      var url  = typeof args[0] === 'string' ? args[0] : (args[0] && args[0].url) || '';
      var p    = _origFetch.apply(this, args);
      if (url.indexOf('/cart/add') !== -1) {
        p.then(function () {
          fetch('/cart.js').then(function (r) { return r.json(); }).then(function (cart) {
            document.dispatchEvent(new CustomEvent('carttotalitems', {
              detail: { itemCount: cart.item_count }
            }));
          });
        }).catch(function () {});
      }
      return p;
    };
  }

  /* Main */
  function run() {
    patchGoodcraftPortalCSS();
    upsizeImages();
    addRemoveButtons();
    attachContainerWatcher();
  }

  new MutationObserver(run).observe(document.body, { childList: true, subtree: true });
  run();
})();
</script>
  <script>
const el = document.querySelector('.product_list-wrapper');
const wrapper = el.querySelector('.w-dyn-items');
const mq = window.matchMedia('(max-width: 776px)');
let swiper;
function initSwiper() {
  if (mq.matches && !swiper) {
    el.classList.add('swiper');
    wrapper.classList.add('swiper-wrapper');
    swiper = new Swiper(el, {
      slidesPerView: 1.2,
      spaceBetween: 16,
      grabCursor: true,
      mousewheel: { forceToAxis: true },
    });
  } else if (!mq.matches && swiper) {
    swiper.destroy(true, true);
    swiper = null;
    el.classList.remove('swiper');
    wrapper.classList.remove('swiper-wrapper');
  }
}
mq.addEventListener('change', initSwiper);
initSwiper();
</script>
