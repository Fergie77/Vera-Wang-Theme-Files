    'position:absolute !important;top:0 !important;left:50% !important;' +
    'right:0 !important;bottom:0 !important;width:50% !important;' +
    'max-width:100% !important;height:100% !important;' +
    'transform:translateX(0) !important;transition:transform 0.4s ease !important;' +
    'overflow:hidden !important;z-index:2002 !important;';

  var DESKTOP_HIDDEN =
    'position:absolute !important;top:0 !important;left:50% !important;' +
    'right:0 !important;bottom:0 !important;width:50% !important;' +
    'max-width:100% !important;height:100% !important;' +
    'transform:translateX(100%) !important;transition:transform 0.4s ease !important;' +
    'overflow:hidden !important;z-index:2002 !important;';

  var DESKTOP_HIDDEN_INSTANT =
    'position:absolute !important;top:0 !important;left:50% !important;' +
    'right:0 !important;bottom:0 !important;width:50% !important;' +
    'max-width:100% !important;height:100% !important;' +
    'transform:translateX(100%) !important;transition:none !important;' +
    'z-index:2002 !important;overflow:hidden !important;';

  var MOBILE_SHOWN =
    'position:absolute !important;top:auto !important;left:0 !important;' +
    'right:0 !important;bottom:0 !important;width:100% !important;' +
    'max-width:100% !important;height:auto !important;' +
    'min-height:80dvh !important;max-height:92dvh !important;' +
    'transform:translateY(0) !important;transition:transform 0.4s ease !important;' +
    'z-index:2002 !important;overflow:hidden !important;';

  var MOBILE_HIDDEN =
    'position:absolute !important;top:auto !important;left:0 !important;' +
    'right:0 !important;bottom:0 !important;width:100% !important;' +
    'max-width:100% !important;height:auto !important;' +
    'min-height:80dvh !important;max-height:92dvh !important;' +
    'transform:translateY(100%) !important;transition:transform 0.4s ease !important;' +
    'z-index:2002 !important;overflow:hidden !important;';

  var MOBILE_HIDDEN_INSTANT =
    'position:absolute !important;top:auto !important;left:0 !important;' +
    'right:0 !important;bottom:0 !important;width:100% !important;' +
    'max-width:100% !important;height:auto !important;' +
    'min-height:80dvh !important;max-height:92dvh !important;' +
    'transform:translateY(100%) !important;transition:none !important;' +
    'z-index:2002 !important;overflow:hidden !important;';

  var _busy = false;

  function setPW(style, holdMs) {
    var pw = getWishlistPanelWrapper();
    if (!pw) return;
    _busy = true;
    pw.style.cssText = style;
    setTimeout(function () { _busy = false; }, holdMs || 30);
  }

  function applyDesktopOpen() {
    var pw = getWishlistPanelWrapper();
    if (!pw) return;
    _busy = true;
    pw.style.cssText = DESKTOP_HIDDEN_INSTANT;
    setTimeout(function () {
      pw.style.cssText = DESKTOP_SHOWN;
      setTimeout(function () { _busy = false; }, 600);
    }, 20);
  }

  function applyDesktopHidden() { setPW(DESKTOP_HIDDEN, 600); }

  function applyMobileOpen() {
    var pw = getWishlistPanelWrapper();
    if (!pw) return;
    _busy = true;
    pw.style.cssText = MOBILE_HIDDEN_INSTANT;
    setTimeout(function () {
      pw.style.cssText = MOBILE_SHOWN;
      setTimeout(function () { _busy = false; }, 600);
    }, 20);
  }

  function applyMobileHidden() { setPW(MOBILE_HIDDEN, 600); }

  var _updateCount = 0;
  function updateWishlistUI(reason) {
    _updateCount++;
    var closeBtns = document.querySelectorAll('.nm-wishlist-drawer-header .nm-modal-close-button');
    var cards = document.querySelectorAll('.nm-wishlist-item-card');
    LOG('updateWishlistUI #' + _updateCount, '(reason: ' + (reason || 'unknown') + ')',
        'closeBtns=', closeBtns.length, 'cards=', cards.length);

    closeBtns.forEach(function (btn, i) {
      Array.from(btn.childNodes).forEach(function (n) {
        if (n.nodeType === 1 && (n.nodeName === 'svg' || n.nodeName === 'SVG')) n.style.display = 'none';
      });
      var hadText = !!btn.querySelector('.nm-close-text');
      var hadX = !!btn.querySelector('.nm-close-x');
      if (!hadText) {
        var t = document.createElement('span'); t.className = 'nm-close-text'; t.textContent = 'Close'; btn.appendChild(t);
      }
      if (!hadX) {
        var x = document.createElement('span'); x.className = 'nm-close-x'; x.innerHTML = X_SVG; btn.appendChild(x);
      }
      if (!hadText || !hadX) LOG('  closeBtn[' + i + '] injected text=' + !hadText + ' x=' + !hadX);
    });

    /* Direct queries on the card — survives Goodcraft's row-shape variations. */
    cards.forEach(function (card, i) {
      var img = card.querySelector('.nm-wishlist-item-image');
      var titleBlock = card.querySelector('.nm-wishlist-item-title');
      var removeBtn = card.querySelector('.nm-wishlist-item-remove-button');
      var rowCount = card.children.length;
      LOG('  card[' + i + '] rows=' + rowCount,
          'img=' + !!img,
          'titleBlock=' + !!titleBlock,
          'removeBtn=' + !!removeBtn,
          'removeBtnIn=', removeBtn ? (titleBlock && titleBlock.contains(removeBtn) ? 'titleBlock' : 'elsewhere') : 'none');

      if (img && !img.dataset.hiresApplied) {
        var base = (img.getAttribute('src') || '').split('?')[0];
        if (base) { img.setAttribute('src', base + '?width=800'); img.dataset.hiresApplied = '1'; LOG('    upsized image src'); }
      }

      if (titleBlock && removeBtn && !titleBlock.contains(removeBtn)) {
        removeBtn.querySelectorAll('img').forEach(function (i2) { i2.style.display = 'none'; });
        if (!removeBtn.querySelector('.nm-remove-text')) {
          var s = document.createElement('span'); s.className = 'nm-remove-text'; s.textContent = 'REMOVE'; removeBtn.appendChild(s);
          LOG('    appended REMOVE text span');
        }
        titleBlock.appendChild(removeBtn);
        LOG('    moved removeBtn into titleBlock');
      } else if (!titleBlock) {
        LOG('    SKIP: no titleBlock found in card');
      } else if (!removeBtn) {
        LOG('    SKIP: no removeBtn found in card');
      }
    });
  }

  function attachPanelObserver(pw, container) {
    if (window._wishlistPanelObserver) window._wishlistPanelObserver.disconnect();
    window._wishlistPanelObserver = new MutationObserver(function () {
      if (_busy) { LOG('panelObserver fire (BUSY, skip)'); return; }
      /* Goodcraft writes translateX on the wrapper for both desktop opens and
         (incorrectly, on mobile) the slide. We catch the rewrite and force
         the correct state for the current breakpoint. */
      if (pw.style.cssText.indexOf('translateX') !== -1) {
        var open = isContainerOpen(container);
        LOG('panelObserver fire — translateX detected; mobile=' + isMobile() + ', open=' + open);
        if (isMobile()) {
          if (open) { applyMobileOpen(); } else { applyMobileHidden(); }
        } else {
          if (open) { applyDesktopOpen(); } else { applyDesktopHidden(); }
        }
      }
    });
    window._wishlistPanelObserver.observe(pw, { attributes: true, attributeFilter: ['style'] });
    LOG('panelObserver attached');
  }

  function attachContainerObserver(wContainer) {
    if (window._wishlistVisibilityObserver) window._wishlistVisibilityObserver.disconnect();
    window._wishlistVisibilityObserver = new MutationObserver(function () {
      var isOpen = isContainerOpen(wContainer);
      LOG('containerObserver fire — open=' + isOpen + ', mobile=' + isMobile());
      if (isMobile()) {
        if (isOpen) applyMobileOpen(); else applyMobileHidden();
      } else {
        if (isOpen) applyDesktopOpen(); else applyDesktopHidden();
      }
      if (isOpen) updateWishlistUI('container-open');
    });
    window._wishlistVisibilityObserver.observe(wContainer, { attributes: true, attributeFilter: ['style'] });
    LOG('containerObserver attached');
  }

  function attachContentObserver(wContainer) {
    if (window._wishlistObserver) window._wishlistObserver.disconnect();
    window._wishlistObserver = new MutationObserver(function (muts) {
      clearTimeout(window._wishlistObserverTimer);
      window._wishlistObserverTimer = setTimeout(function () {
        LOG('contentObserver fire (debounced) — ' + muts.length + ' mutation(s)');
        updateWishlistUI('content-mutation');
      }, 50);
    });
    window._wishlistObserver.observe(wContainer, { childList: true, subtree: true });
    LOG('contentObserver attached');
  }

  function init() {
    var wContainer = getWishlistContainer();
    var pw = getWishlistPanelWrapper();
    LOG('init lookup: wContainer=', wContainer, 'pw=', pw);
    if (!wContainer || !pw) return false;

    LOG('init: applying initial panel styles; mobile=' + isMobile());
    _busy = true;
    pw.style.cssText = isMobile() ? MOBILE_HIDDEN_INSTANT : DESKTOP_HIDDEN_INSTANT;
    setTimeout(function () { _busy = false; }, 100);
    attachContainerObserver(wContainer);
    attachPanelObserver(pw, wContainer);
    attachContentObserver(wContainer);
    updateWishlistUI('init');

    /* Catch late re-renders by Goodcraft (a manual resize used to fix it —
       these scheduled runs do the same automatically). */
    [150, 400, 800, 1500, 3000].forEach(function (ms) {
      setTimeout(function () { updateWishlistUI('retry-' + ms + 'ms'); }, ms);
    });
    return true;
  }

  /* Goodcraft injects its portal asynchronously after our script runs.
     Try init immediately; if the portal isn't there yet, poll for it. */
  if (!init()) {
    LOG('portal not ready — polling for Goodcraft portal');
    var pollAttempts = 0;
    var pollInterval = setInterval(function () {
      pollAttempts++;
      if (init()) {
        LOG('portal found after ' + pollAttempts + ' poll(s)');
        clearInterval(pollInterval);
      } else if (pollAttempts >= 100) { // 100 * 100ms = 10s max
        LOG('giving up portal poll after ' + pollAttempts + ' attempts');
        clearInterval(pollInterval);
      }
    }, 100);
  }

  if (window._wishlistResizeHandler) window.removeEventListener('resize', window._wishlistResizeHandler);
  window._wishlistResizeHandler = function () {
    clearTimeout(window._wishlistResizeTimer);
    window._wishlistResizeTimer = setTimeout(function () {
      var pw2 = getWishlistPanelWrapper(), c2 = getWishlistContainer();
      LOG('resize handler fire; innerWidth=' + window.innerWidth + ' mobile=' + isMobile() + ' pw2=' + !!pw2 + ' c2=' + !!c2);
      if (!pw2 || !c2) return;
      var open = isContainerOpen(c2);
      _busy = true;
      if (isMobile()) {
        pw2.style.cssText = open ? MOBILE_SHOWN : MOBILE_HIDDEN_INSTANT;
      } else {
        pw2.style.cssText = open ? DESKTOP_SHOWN : DESKTOP_HIDDEN_INSTANT;
      }
      setTimeout(function () { _busy = false; }, 30);
      updateWishlistUI('resize');
    }, 150);
  };
  window.addEventListener('resize', window._wishlistResizeHandler);

})();
</script>
</body>
</html>