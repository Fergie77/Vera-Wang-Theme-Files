<script>
const checkTitleOverflow = () => {
  const titles = document.querySelectorAll('.product-item_title');
  if (!titles.length) return;

  const measurer = document.createElement('span');
  Object.assign(measurer.style, {
    position: 'absolute', visibility: 'hidden', whiteSpace: 'nowrap',
    left: '-99999px', top: '0', pointerEvents: 'none',
  });
  document.body.appendChild(measurer);

  // First pass: clear all flags, find overflowing titles
  const items = [...document.querySelectorAll('.filter_product-list-item')];
  items.forEach(item => item.classList.remove('has-tall-title'));

  titles.forEach(el => {
    const cs = getComputedStyle(el);
    measurer.style.font = cs.font;
    measurer.style.letterSpacing = cs.letterSpacing;
    measurer.style.textTransform = cs.textTransform;
    measurer.textContent = el.textContent;

    const overflow = measurer.getBoundingClientRect().width - el.clientWidth;

    if (overflow > 1) {
      const item = el.closest('.filter_product-list-item');
      const idx = items.indexOf(item);
      const pairStart = idx - (idx % 2);

      items[pairStart]?.classList.add('has-tall-title');
      items[pairStart + 1]?.classList.add('has-tall-title');
    }
  });

  document.body.removeChild(measurer);
};

document.fonts.ready.then(checkTitleOverflow);
window.addEventListener('resize', checkTitleOverflow);
</script>
  <script>
const el = document.querySelector('.product_list-wrapper');
const wrapper = el.querySelector('.w-dyn-items');
const mq = window.matchMedia('(max-width: 776px)');
let swiper;
function initSwiper() {
  if (mq.matches && !swiper) {
    el.classList.add('swiper');
    wrapper.classList.add('swiper-wrapper');
    swiper = new Swiper(el, {
      slidesPerView: 1.2,
      spaceBetween: 16,
      grabCursor: true,
      mousewheel: { forceToAxis: true },
    });
  } else if (!mq.matches && swiper) {
    swiper.destroy(true, true);
    swiper = null;
    el.classList.remove('swiper');
    wrapper.classList.remove('swiper-wrapper');
  }
}
mq.addEventListener('change', initSwiper);
initSwiper();
</script>
