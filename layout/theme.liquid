  <script>
(function () {
  function $ov() { return document.querySelector('[data-cart-overlay]'); }
  function $pn() { return document.querySelector('[data-cart-panel]'); }
  function $bd() { return document.querySelector('[data-cart-close].mini-cart-v2_backdrop'); } // &larr; new
  function openCart() {
    var ov = $ov(), pn = $pn(), bd = $bd();
    if (ov) ov.classList.add('is-open');
    if (pn) pn.classList.add('is-open');
    if (bd) bd.classList.add('is-open');                                                       // &larr; new
    document.body.setAttribute('data-cart-open', 'true');
    window.dispatchEvent(new CustomEvent('cartupdated'));
  }
  function closeCart() {
    var ov = $ov(), pn = $pn(), bd = $bd();
    if (ov) ov.classList.remove('is-open');
    if (pn) pn.classList.remove('is-open');
    if (bd) bd.classList.remove('is-open');                                                    // &larr; new
    document.body.removeAttribute('data-cart-open');
  }
  document.addEventListener('click', function (e) {
    if (e.target.closest('[data-cart-toggle]')) { e.preventDefault(); openCart(); return; }
    if (!document.body.hasAttribute('data-cart-open')) return;
    if (e.target.closest('[data-cart-close]') || e.target.closest('.nav_dropdown-close-button')) {
      e.preventDefault();
      closeCart();
    }
  });
  document.addEventListener('keydown', function (e) {
    if (e.key === 'Escape') closeCart();
  });
  window.addEventListener('toggleminicart', openCart);
})();
</script>
  <script>
const el = document.querySelector('.product_list-wrapper');
const wrapper = el.querySelector('.w-dyn-items');
const mq = window.matchMedia('(max-width: 776px)');
let swiper;
function initSwiper() {
  if (mq.matches && !swiper) {
    el.classList.add('swiper');
    wrapper.classList.add('swiper-wrapper');
    swiper = new Swiper(el, {
      slidesPerView: 1.2,
      spaceBetween: 16,
      grabCursor: true,
      mousewheel: { forceToAxis: true },
    });
  } else if (!mq.matches && swiper) {
    swiper.destroy(true, true);
    swiper = null;
    el.classList.remove('swiper');
    wrapper.classList.remove('swiper-wrapper');
  }
}
mq.addEventListener('change', initSwiper);
initSwiper();
</script>
