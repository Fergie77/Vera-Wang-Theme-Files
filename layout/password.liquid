  <style>
/* =====================================================
   VERA WANG &mdash; POLICY PAGES
   Scoped entirely to Shopify policy pages via
   :has(.shopify-policy__container) and
   .shopify-policy__* selectors.
   No other pages are affected.
===================================================== */
/* &#9472;&#9472; Nav: solid white, black links (policy pages only) &#9472;&#9472;
   :has() detects the policy container on the page and
   overrides the metafield CSS variables on the nav.     */
body:has(.shopify-policy__container) .nav_component {
  --nav-left-link: #000000 !important;
  --nav-left-bg: #ffffff !important;
  --nav-right-link: #000000 !important;
  --nav-right-bg: #ffffff !important;
  --nav-scroll-link: #000000 !important;
  --nav-scroll-bg: #ffffff !important;
  background: #ffffff !important;
}
/* &#9472;&#9472; Clear fixed navbar height &#9472;&#9472; */
@media screen and (min-width: 768px) {
  body:has(.shopify-policy__container) .page-wrapper {
    padding-top: 80px !important;
    overflow: visible !important;
  }
}
/* &#9472;&#9472; DESKTOP: two-column grid &#9472;&#9472; */
.shopify-policy__container {
  max-width: none !important;
  width: 100% !important;
  margin: 0 !important;
  padding: 0 !important;
  display: grid !important;
  grid-template-columns: 40% 60% !important;
  align-items: start !important;
  min-height: calc(100vh - 80px) !important;
}
/* Left column &mdash; sticky page title */
.shopify-policy__title {
  grid-column: 1 !important;
  grid-row: 1 !important;
  position: sticky !important;
  top: 80px !important;
  padding: 3.5rem 2rem 3.5rem var(--padding--global, 1.25rem) !important;
  margin: 0 !important;
  text-align: left !important;
  align-self: start !important;
  border-bottom: none !important;
}
/* h1: Big Caslon */
.shopify-policy__title h1 {
  font-family: 'Big Caslon', 'Big Caslon FB', Georgia, serif !important;
  font-style: normal !important;
  font-weight: 500 !important;
  font-size: clamp(1.875rem, 1.785714rem + 0.446429vw, 2.1875rem) !important;
  line-height: 100% !important;
  letter-spacing: 0.04em !important;
  text-transform: uppercase !important;
  color: #000000 !important;
  margin: 0 !important;
  hyphens: auto !important;
  -webkit-hyphens: auto !important;
}
/* Right column &mdash; body content */
.shopify-policy__body {
  grid-column: 2 !important;
  grid-row: 1 !important;
  padding: 3.5rem 2rem 3.5rem 3rem !important;
  margin: 0 !important;
  border-left: 1px solid rgba(0, 0, 0, 0.12) !important;
  min-height: calc(100vh - 80px) !important;
  hyphens: auto !important;
  -webkit-hyphens: auto !important;
}
/* Section headings &mdash; Recover Password style */
.shopify-policy__body h2,
.rte h2 {
  font-family: 'Helvetica Now Var', Arial, sans-serif !important;
  font-weight: 700 !important;
  font-size: 14px !important;
  line-height: 100% !important;
  letter-spacing: 0.05em !important;
  color: #000000 !important;
  text-transform: uppercase !important;
  margin-top: 2.5rem !important;
  margin-bottom: 0.875rem !important;
}
.rte > div > h2:first-of-type {
  margin-top: 0 !important;
}
/* Body text */
.shopify-policy__body p,
.rte p {
  font-size: 13px !important;
  line-height: 1.65 !important;
  margin-top: 0 !important;
  margin-bottom: 1rem !important;
  color: #000000 !important;
}
/* Lists */
.shopify-policy__body ul,
.rte ul {
  margin-top: 0 !important;
  margin-bottom: 1rem !important;
  padding-left: 1.25rem !important;
}
.shopify-policy__body li,
.rte li {
  font-size: 13px !important;
  line-height: 1.65 !important;
  margin-bottom: 0.4rem !important;
  color: #000000 !important;
}
/* &#9472;&#9472; MOBILE (&le;767px) &#9472;&#9472; */
@media screen and (max-width: 767px) {
  .shopify-policy__container {
    grid-template-columns: 1fr !important;
    grid-template-rows: auto auto !important;
    min-height: unset !important;
  }
  .shopify-policy__title {
    grid-column: 1 !important;
    grid-row: 1 !important;
    position: static !important;
    text-align: center !important;
    padding: 2.5rem 1.25rem 2rem 1.25rem !important;
    border-bottom: 1px solid rgba(0, 0, 0, 0.15) !important;
  }
  .shopify-policy__body {
    grid-column: 1 !important;
    grid-row: 2 !important;
    border-left: none !important;
    padding: 2rem 1.25rem 3rem 1.25rem !important;
    min-height: unset !important;
  }
  .shopify-policy__body h2,
  .rte h2 {
    margin-top: 2rem !important;
  }
}
/* Suppress all transitions during window resize to prevent modals sliding on breakpoint change */
.resize-transition-stopper,
.resize-transition-stopper * {
  transition: none !important;
}
