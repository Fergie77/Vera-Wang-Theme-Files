    });
    return true;
  }
  /* Goodcraft injects its portal asynchronously after our script runs.
     Try init immediately; if the portal isn't there yet, poll for it. */
  if (!init()) {
    var pollAttempts = 0;
    var pollInterval = setInterval(function () {
      pollAttempts++;
      if (init() || pollAttempts >= 100) clearInterval(pollInterval);
    }, 100);
  }
  if (window._wishlistResizeHandler) window.removeEventListener('resize', window._wishlistResizeHandler);
  window._wishlistResizeHandler = function () {
    clearTimeout(window._wishlistResizeTimer);
    window._wishlistResizeTimer = setTimeout(function () {
      var pw2 = getWishlistPanelWrapper(), c2 = getWishlistContainer();
      if (!pw2 || !c2) return;
      var open = isContainerOpen(c2);
      _busy = true;
      if (isMobile()) {
        pw2.style.cssText = open ? MOBILE_SHOWN : MOBILE_HIDDEN_INSTANT;
      } else {
        pw2.style.cssText = open ? DESKTOP_SHOWN : DESKTOP_HIDDEN_INSTANT;
      }
      setTimeout(function () { _busy = false; }, 30);
      updateWishlistUI();
    }, 150);
  };
  window.addEventListener('resize', window._wishlistResizeHandler);
})();
</script>
  <script>
(function () {
  let resizeTimer;
  window.addEventListener('resize', function () {
    document.body.classList.add('resize-transition-stopper');
    clearTimeout(resizeTimer);
    resizeTimer = setTimeout(function () {
      document.body.classList.remove('resize-transition-stopper');
    }, 400); // 400ms matches the longest transition duration in use (.4s cart, .6s search)
  });
})();
</script>
