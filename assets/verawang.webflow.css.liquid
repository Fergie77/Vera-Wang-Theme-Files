  border-top-width: 1px;
  border-top-color: var(--base-color-neutral--black);
  border-right-style: solid;
  border-right-width: 1px;
  border-right-color: var(--base-color-neutral--black);
  border-bottom-style: solid;
  border-bottom-width: 1px;
  border-bottom-color: var(--base-color-neutral--black);
  border-left-style: solid;
  border-left-width: 1px;
  border-left-color: var(--base-color-neutral--black);
  color: var(--base-color-neutral--black);
  text-align: center;
  letter-spacing: .15em;
  text-transform: uppercase;
  white-space: nowrap;
  background-color: #0000;
  width: 100%;
  padding: 1rem 1.5rem;
  font-family: Gotham, Arial, sans-serif;
  font-size: clamp(.625rem, .579082rem + .229592vw, .785714rem);
  font-weight: 500;
  transition-property: background-color, color;
  transition-duration: .2s, .2s;
  transition-timing-function: ease-in-out, ease-in-out;
}

.button:hover {
  background-color: var(--background-color--background-primary);
  color: var(--base-color-neutral--white);
}

.button.is-secondary {
  border: 1px solid var(--base-color-neutral--black);
  color: #000;
  background-color: #0000;
}

.button.is-outline {
  color: #111;
  background-color: #0000;
  border: 1px solid #111;
  transition: color .2s, background-color .2s;
}

.button.is-outline:hover {
  color: #fff;
  background-color: #111;
}

.button.is-link {
  color: var(--base-color-neutral--black);
  background-color: #0000;
  border-style: none;
  padding: .25rem 0;
  line-height: 1;
