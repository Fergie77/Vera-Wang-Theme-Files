<div class="header_background-image-wrapper is-relative">
          <div class="header_background-image is-full-width">{% if section.settings.image_image %}
{{ section.settings.image_image | image_url: width: 2000 | image_tag: li-unless: 'section.settings.video', loading: 'eager', class: 'header_background-image_item is-left' }}
{% else %}
 {{ 'detailed-apparel-1' | placeholder_svg_tag: 'header_background-image_item is-left' }} 
{% endif %}
            {% if section.settings.video | video_tag %}    <div li-if="section.settings.video" li-object="section.settings.video | video_tag" class="header_background-image_item is-left">
        </div>
{% endif %}
            
            <div class="hero-text-absolute-wrapper">
              <h1 li-block="Heading" class="hero_heading">
{{ section.settings.text_heading }}
</h1>
              <p li-block="Subheading" class="hero_subheading">
{{ section.settings.text_subheading }}
</p>
              <div class="cta-text" style="color:{{section.settings.text_color}}">
{{ section.settings.text_cta_text }}
</div>
            </div>
            
          </div>
          <a href="{{ section.settings.url_cta_link }}" class="header_link w-inline-block"> </a>
        </div> {% schema %} {
    "tag": "header",
    "name": "Full Width Hero",
    "class": "section_header-home",
    "settings": [
        {
            "id": "image_image",
            "type": "image_picker",
            "label": "Image"
        },
        {
            "type": "header",
            "content": "Video"
        },
        {
            "type": "video",
            "id": "video",
            "label": "Video"
        },
        {
            "id": "text_heading",
            "type": "text",
            "label": "Heading",
            "default": "Headline Goes here"
        },
        {
            "id": "text_subheading",
            "type": "text",
            "label": "Subheading",
            "default": "SPRING SUMMER 26"
        },
        {
            "id": "text_cta_text",
            "type": "text",
            "label": "CTA Text",
            "default": "Shop the collection"
        },
        {
            "type": "header",
            "content": "Text Color"
        },
        {
            "type": "color",
            "id": "text_color",
            "label": "Text Color",
            "default": "#000000"
        },
        {
            "id": "url_cta_link",
            "type": "url",
            "label": "CTA Link"
        }
    ],
    "presets": [
        {
            "name": "Full Width Hero",
            "category": "Liquify",
            "blocks": []
        }
    ]
} {% endschema %}