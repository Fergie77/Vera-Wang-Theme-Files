<div class="header_background-image-wrapper">
          <div class="header_background-image is-full-width">{% if section.settings.image_image %}
{{ section.settings.image_image | image_url: width: 2000 | image_tag: loading: 'eager', class: 'header_background-image_item is-left' }}
{% else %}
 {{ 'detailed-apparel-1' | placeholder_svg_tag: 'header_background-image_item is-left' }} 
{% endif %}
            <div class="cta-text is-absolute" style="color:{{section.settings.text_color}}">
{{ section.settings.text_link_text }}
</div>
            
          </div>
          <a href="{{ section.settings.url_link }}" class="header_link w-inline-block"> </a>
        </div> {% schema %} {
    "tag": "header",
    "name": "Full Width Hero",
    "class": "section_header-home",
    "settings": [
        {
            "id": "image_image",
            "type": "image_picker",
            "label": "Image"
        },
        {
            "id": "text_link_text",
            "type": "text",
            "label": "Link Text",
            "default": "Shop the collection"
        },
        {
            "type": "header",
            "content": "Links"
        },
        {
            "type": "color",
            "id": "text_color",
            "label": "Text Color",
            "default": "#000000"
        },
        {
            "id": "url_link",
            "type": "url",
            "label": "Link"
        }
    ],
    "presets": [
        {
            "name": "Full Width Hero",
            "category": "Liquify",
            "blocks": []
        }
    ]
} {% endschema %}