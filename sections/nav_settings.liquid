<div class="w-embed w-script">{% if section.settings.nav_scroll_animation %}
          <script>
  gsap.registerPlugin(ScrollTrigger);
  ScrollTrigger.create({
    start: "top -5%",
    onEnter: () => document.querySelector(".section_navbar").classList.add("scrolling"),
    onLeaveBack: () => document.querySelector(".section_navbar").classList.remove("scrolling"),
  });
</script>
          {% endif %}
        </div> {% schema %} {
    "tag": "div",
    "name": "Nav Settings",
    "settings": [
        {
            "type": "header",
            "content": "Nav Colour"
        },
        {
            "type": "checkbox",
            "id": "nav_scroll_animation",
            "label": "Enable scroll animation",
            "default": true
        }
    ],
    "presets": [
        {
            "name": "Nav Settings",
            "category": "Liquify",
            "blocks": []
        }
    ]
} {% endschema %}