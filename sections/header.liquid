                  <script>
const input = document.querySelector('#search-input');
const overflow = document.querySelector('.predictive-search_overflow');
const closePanel = document.querySelector('.nav_predictive-search-close-blur');
const closeButton = document.querySelector('.nav_predictive-search-close-button');
function open() {
  overflow.classList.add('is-open');
  closePanel.classList.add('is-open');
}
function close() {
  overflow.classList.remove('is-open');
  closePanel.classList.remove('is-open');
}
input.addEventListener('focus', open);
input.addEventListener('click', (e) => e.stopPropagation());
closePanel.addEventListener('click', close);
closeButton.addEventListener('click', close);
document.addEventListener('keydown', (e) => {
  if (e.key === 'Escape') close();
});
document.addEventListener('click', (e) => {
  if (!overflow.contains(e.target)) close();
});
</script>
