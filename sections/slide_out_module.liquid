                <div class="dropdown_icon-inner is-top"></div>
                <div class="dropdown_icon-inner is-bottom"></div>
              </div>
            </a>
                    
            
                    <div class="dropdown_list-wrapper is-open">
              <div class="dropdown_list w-richtext"> {{ block.settings.richtext_content }} </div>
            </div>
                    
            
                    <div class="hide w-embed w-script">
              <script>
  (function () {
    const script = document.currentScript;
    const root = script ? script.closest('.dropdown_wrapper') : null;
    if (!root) return;
    const toggle = root.querySelector('.dropdown_toggle');
    const list = root.querySelector('.dropdown_list-wrapper');
    const iconInner = root.querySelector('.dropdown_icon-inner.is-top');
    if (!toggle || !list || !iconInner) return;
    const isWebflowEditor =
      window.Webflow &&
      typeof window.Webflow.env === 'function' &&
      window.Webflow.env('editor');
    if (!isWebflowEditor) {
      list.classList.remove('is-open');
    }
    toggle.addEventListener('click', () => {
      list.classList.toggle('is-open');
      iconInner.classList.toggle('is-open');
    });
  })();
</script>
            </div>
                    
          
                </div>
        {% endcase %}
{% endfor %}

