        <div class="padding-global">
          <div class="container-large">
            <div class="support_layout">
              <h1 li-object:text="page.title" class="support_heading">
{{ page.title }}
</h1>
              <div class="support-dropdowns_wrapper">
                <div class="support-dropdowns_layout">
                  {% for block in section.blocks %}
    {% if block.type == "support-dropdown" %}
                    <div li-block="Support Dropdown" class="dropdown_wrapper">
                                    
                    
                                    <a href="#" class="support-dropdown_toggle w-inline-block">
                      <h2 class="support-dropdown_title">
{{ block.settings.text_heading }}
</h2>
                      <div class="support-dropdown_icon"><svg xmlns="http://www.w3.org/2000/svg" width="100%" viewbox="0 0 13 9" fill="none" class="dropdown_svg">
                          <path d="M0 0H1.96377L4.23188 3.16384L6.5 0L8.76812 3.16384L11.0362 0H13L6.5 9L0 0Z" fill="#C1BFBF"></path>
                        </svg></div>
                    </a>
                                    
                    
                                    <div class="support-dropdown_list-wrapper">
                      <div class="dropdown_list w-richtext"> {{ block.settings.richtext_content }} </div>
                    </div>
                                    
                    
                                    <div class="hide w-embed w-script">
                      <script>
  (function () {
    const root = document.currentScript.closest('.dropdown_wrapper');
    const toggle = root.querySelector('.support-dropdown_toggle');
    const list = root.querySelector('.support-dropdown_list-wrapper');
    const icon = root.querySelector('.support-dropdown_icon');
    if (!window.Webflow || !window.Webflow.env('editor')) {
      list.classList.remove('is-open');
    }
    toggle.addEventListener('click', () => {
      list.classList.toggle('is-open');
      icon.classList.toggle('is-open');
    });
  })();
</script>
                    </div>
                                    
                  
                            </div>
            {% endif %}
{% endfor %}
                  {% for block in section.blocks %}
    {% if block.type == "content" %}
                    <div li-block="Content">
                                    
                    
                                    <div class="text-rich-text w-richtext"> {{ block.settings.richtext_content }} </div>
                                    
                  
                            </div>
            {% endif %}
{% endfor %}
                </div>
              </div>
            </div>
          </div>
