<section class="section_article">
          <div class="padding-global">
            <div class="container-large">
              <div class="article_wrapper">
                <div id="w-node-_21ceba6d-c246-1e44-8f4f-1e1423123a81-5b2f753a" class="content-header_image-wrapper">
                  <div class="header_background-image-wrapper">
                    <div class="header_overlay-layer"></div><img src="{{ article.image | image_url: width: 1000 }}" loading="eager" li-object:src="article.image | image_url: width: 1000" li-object:alt="article.image.alt" alt="{{ article.image.alt }}" class="header_background-image_item">
                  </div>
                  {% if section.settings.image_headline == true %}    <div li-if="section.settings.image_headline == true">
    
                    <h1 li-object="article.title" class="content-header_heading is-flipped text-color-white">{{ article.title }}</h1>
                      </div>
{% endif %}
                </div>
                <div class="article_text-container">
                  {% unless section.settings.image_headline == true %}    <div li-unless="section.settings.image_headline == true">
    
                    <h1 li-object="article.title" class="content-header_heading">{{ article.title }}</h1>
                      </div>
{% endunless %}
                  <div li-object="article.content" class="text-rich-text w-richtext">{{ article.content }}</div>
                </div>
                
              </div>
            </div>
          </div>
        </section> {% schema %} {
    "tag": "div",
    "name": "Article Content",
    "settings": [
        {
            "type": "header",
            "content": "Show\/Hide Image"
        },
        {
            "type": "checkbox",
            "id": "image_headline",
            "label": "Image Headline",
            "default": true
        }
    ],
    "presets": [
        {
            "name": "Article Content",
            "category": "Liquify",
            "blocks": []
        }
    ],
    "enabled_on": {
        "templates": [
            "article"
        ]
    }
} {% endschema %}