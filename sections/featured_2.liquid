<div class="padding-global padding-section-medium">
          <div class="container-large">
            <div class="product_component">
              <div class="featured-products-component_layout">
                <div id="w-node-_6327b60e-44ca-c0c8-eaac-83b50b20f8e5-feb34c80" class="product_heading is-grid">
                  <h2 id="w-node-_6327b60e-44ca-c0c8-eaac-83b50b20f8e6-feb34c80" class="product-section_heading is-large">
{{ section.settings.text_heading }}
</h2>
                  <p id="w-node-_6327b60e-44ca-c0c8-eaac-83b50b20f8e8-feb34c80" class="product-section_subheading is-small">
{{ section.settings.text_paragraph }}
</p>
                  <div id="w-node-_6327b60e-44ca-c0c8-eaac-83b50b20f8ea-feb34c80" class="cta-text">
{{ section.settings.text_link_text }}
</div>
                </div>
                <div id="w-node-_12ade119-ddf2-a571-f17d-2b2413af1788-feb34c80" class="slider-mobile-wrapper">
                  <div id="w-node-_85c3723d-2e12-1395-677e-166d97d4d035-feb34c80" class="w-dyn-list">
                    <div role="list" class="featured-products_layout w-dyn-items">
                      {% for product in section.settings.collection_collection.products limit: section.settings.collection_collection_limit %}
<div role="listitem" class="featured-products_item w-dyn-item">
    
                        
    {% render 'product_item', product: product %}
    
                      
</div>
{% endfor %}
                    </div>
                    <div class="hide w-dyn-empty">
                      <div>No items found.</div>
                    </div>
                  </div>
                </div>
                <div id="w-node-a96a619b-ba2d-8598-5535-0e3f407f9f82-feb34c80" class="featured-products_collection-link-wrapper">{% if section.settings.image_link_image %}
{{ section.settings.image_link_image | image_url: width: 1000 | image_tag: loading: 'lazy', class: 'featured-products_collection-image' }}
{% else %}
<img loading="lazy" alt="" src="https://d3e54v103j8qbb.cloudfront.net/plugins/Basic/assets/placeholder.60f9b1840c.svg" class="featured-products_collection-image">
{% endif %}
                  <div class="featured-products_collection-link-text">
{{ section.settings.text_link_image_text }}
</div>
                  <a li-if="Link Image URL != blank" href="{{ section.settings.url_link_image_url }}" class="featured-products_collection-link w-inline-block"> </a>
                </div>
              </div>
            </div>
          </div>
        </div> {% schema %} {
    "tag": "section",
    "name": "Featured 2",
    "class": "section_product",
    "settings": [
        {
            "id": "text_heading",
            "type": "text",
            "label": "Heading",
            "default": "Shoes"
        },
        {
            "id": "text_paragraph",
            "type": "text",
            "label": "Paragraph",
            "default": "Lorem ipsum dolor sit amet consecteturadipiscing elit Vestibulumelementum elit sit amet dictum tempus"
        },
        {
            "id": "text_link_text",
            "type": "text",
            "label": "Link Text",
            "default": "View More"
        },
        {
            "id": "collection_collection",
            "type": "collection",
            "label": "Collection"
        },
        {
            "type": "range",
            "id": "collection_collection_limit",
            "min": 1,
            "max": 99,
            "step": 1,
            "label": "Limit: Collection",
            "default": 6
        },
        {
            "id": "image_link_image",
            "type": "image_picker",
            "label": "Link Image"
        },
        {
            "id": "text_link_image_text",
            "type": "text",
            "label": "Link Image Text",
            "default": "Shop the collection"
        },
        {
            "id": "url_link_image_url",
            "type": "url",
            "label": "Link Image URL"
        }
    ],
    "presets": [
        {
            "name": "Featured 2",
            "category": "Liquify",
            "blocks": []
        }
    ]
} {% endschema %}