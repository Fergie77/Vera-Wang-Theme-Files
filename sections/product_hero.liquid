                            </div>
{% endif %}
                          </div>
{% endif %}
                            
                      
                            {% if media.alt contains product.selected_or_first_available_variant.option1 %}    <div li-if="media.alt contains product.selected_or_first_available_variant.option1" class="swiper-slide is-product-gallery">
    
                        {% if media.media_type == 'video' %}    <div li-if="media.media_type == 'video'">
    
                          <div class="product-header_gallery-lightbox">
                            <div li-object="media | video_tag: controls: true" class="product-header_gallery-image">{{ media | video_tag: controls: true }}</div>
                          </div>
                            </div>
{% endif %}
                          </div>
{% endif %}
                            
                    
                        </div>
{% endfor %}
