    if (e.target.closest('[data-select-size]')){
      e.preventDefault();
      open();
      return;
    }
    if (
      e.target.closest('[data-drawer-close]') ||
      e.target.matches('[data-drawer-backdrop]')
    ){
      close();
    }
  });
  document.addEventListener('change', function(e){
    var input = e.target.closest('[li-element="product-option-input"]');
    if (!input) return;
    if (input.closest('[data-option="Size" i]')){
