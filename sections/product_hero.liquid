<div>
          <div class="container-large">
            <div class="product-header_component">
              <script src="{{ 'li_custom.js' | asset_url }}" type="text/javascript"></script>
<div li-element="product-variant-container" class="w-layout-grid product-header_layout" x-data="handleVariant({{ product | json | escape }}, {{ product.options_by_name | json | escape }}, {{ product.selected_or_first_available_variant | json | escape }})" x-init="$nextTick(() => { activateVariants() })" @setbundleitem.window="updateBundleItem($event.detail.product, $event.detail.quantity)">
                <div id="w-node-_4b0e9b61-6f53-1185-9fdd-143753136862-5313685d" class="swiper-container is-product-gallery">
                  <div class="swiper is-product-gallery">
                    <div id="my-gallery" li-for:inside="media in product.media" class="swiper-wrapper is-product-gallery">
        {% for media in product.media %}                            
                      
                            {% if media.media_type == 'image' %}    <div li-if="media.media_type == 'image'" class="swiper-slide is-product-gallery">
    
                        <div class="product-header_gallery-lightbox"><img loading="lazy" li-object:src="media | image_url: width: 1000" li-object:alt="media.alt" src="{{ media | image_url: width: 1000 }}" alt="{{ media.alt }}" class="product-header_gallery-image"></div>
                          </div>
{% endif %}
                            
                      
                            {% if media.media_type == 'video' %}    <div li-if="media.media_type == 'video'" class="swiper-slide is-product-gallery">
    
                        <div class="product-header_gallery-lightbox">
                          <div li-object="media | video_tag: controls: true" class="product-header_gallery-image">{{ media | video_tag: controls: true }}</div>
                        </div>
                          </div>
{% endif %}
                            
                    
                    {% endfor %}    </div>
                    <div class="swiper-pagination"></div>
                  </div>
                </div>
                <div id="w-node-_0fed1a94-1f90-abfd-cc0c-dda684148897-5313685d" class="product-details_wrapper">
                  <a href="{{product.collections.first.url}}" class="product-details_backlink-wrapper w-inline-block">
                    <div class="product-details_backlink"><</div>
                    <p li-object="product.collections.first.title" class="product-details_backlink">{{ product.collections.first.title }}</p>
                  </a>
                  <div li-content-for-theme-blocks="" class="product-header_product-details">
{% content_for 'blocks' %}
</div>
                </div>
              </div>
            </div>
          </div>
        </div>
        <div class="hide w-embed w-script">
          <script src="https://cdn.jsdelivr.net/npm/swiper@9/swiper-bundle.min.js"></script>
          <script>
document.addEventListener("DOMContentLoaded", () => {
  $(".swiper-container").each(function () {
    new Swiper($(this).find(".swiper.is-product-gallery")[0], {
      mousewheel: { forceToAxis: true },
      keyboard: { enabled: true, onlyInViewport: true },
      pagination: {
        el: $(this).find(".swiper-pagination")[0],
        clickable: true,
        direction: "vertical",
      },
    });
  });
});
</script>
          <style>
.swiper-pagination-bullet {
  width: 8px;
  height: 8px;
  background: transparent;
  border: 1px solid white;
  border-radius: 50%;
  display: block;
}
.swiper-pagination-bullet-active {
  background: white;
}
</style>
        </div> {% schema %} {
    "tag": "section",
    "name": "Product Hero",
    "class": "section_product-header",
    "blocks": [
        {
            "type": "product-name"
        },
        {
            "type": "product-price"
        },
        {
            "type": "add-to-cart"
        },
        {
            "type": "description"
        },
        {
            "type": "@app"
        }
    ],
    "presets": [
        {
            "name": "Product Hero",
            "category": "Liquify",
            "blocks": [
                {
                    "type": "product-name"
                },
                {
                    "type": "product-price"
                },
                {
                    "type": "add-to-cart"
                },
                {
                    "type": "description"
                }
            ]
        }
    ],
    "enabled_on": {
        "templates": [
            "product"
        ]
    }
} {% endschema %}