          <script>
(function(){
  var slot = function(){ 
    return document.querySelector('[data-drawer-slot]'); 
  };
  var sizeOpt = function(){ 
    return document.querySelector('[data-option="Size" i]'); 
  };
  var origParent = null, origNext = null;
  function open(){
    var opt = sizeOpt(), target = slot();
    if (!opt || !target) return;
    if (!origParent){
      origParent = opt.parentNode;
      origNext = opt.nextSibling;
    }
    target.appendChild(opt);
    document.body.setAttribute('data-drawer-open', 'size-picker');
  }
  function close(){
    var opt = sizeOpt();
    if (opt && origParent){
      origParent.insertBefore(opt, origNext);
    }
    origParent = null;
    origNext = null;
    document.body.removeAttribute('data-drawer-open');
  }
  function setChosen(v){
    if (v){
      document.body.setAttribute('data-size-chosen', 'true');
    } else {
      document.body.removeAttribute('data-size-chosen');
    }
  }
  document.addEventListener('click', function(e){
    // Tapping an already-checked radio doesn't fire change;
    // handle it here so the pre-selected first size still confirms.
    var label = e.target.closest('label');
