                <div class="w-embed w-script">
                  <script>
function initGallery() {
  ScrollTrigger.getAll()
    .filter(st => st.vars._gallery)
    .forEach(st => st.kill());
  const slides = gsap.utils.toArray('.swiper-slide.is-product-gallery');
  const bullets = gsap.utils.toArray('.swiper-pagination-bullet');
  function setActive(index) {
    bullets.forEach((b, i) => b.classList.toggle('is-active', i === index));
  }
  slides.forEach((slide, i) => {
    ScrollTrigger.create({
      trigger: slide,
      start: 'top center',
      end: 'bottom center',
      onEnter: () => setActive(i),
      onEnterBack: () => setActive(i),
      vars: { _gallery: true },
    });
  });
}
initGallery();
</script>
