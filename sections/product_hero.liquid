  document.querySelectorAll('.module_background-blur').forEach(blur => {
    blur.addEventListener('click', () => closeModule(blur.parentElement.querySelector('[module]')));
  });
  document.addEventListener('keydown', (e) => {
    if (e.key !== 'Escape') return;
