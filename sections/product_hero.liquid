document.addEventListener("DOMContentLoaded", () => {
  document.addEventListener("change", (e) => {
    const input = e.target.closest('[li-element="product-option-input"]');
    if (!input) return;
    const wrapper = input.closest('[li-render-custom="wrapper"]');
    if (!wrapper) return;
    const alpineData = Alpine.$data(wrapper.querySelector('[x-data]') || wrapper);
    const variantId = alpineData?.selected_or_first_available_variant?.id;
    if (!variantId) return;
    const target = wrapper.querySelector('[li-render-custom="target"]');
    if (!target) return;
    const sectionId = input.closest('form')?.querySelector('[name="section-id"]')?.value;
    const productUrl = window.location.pathname;
    fetch(`${productUrl}?section_id=${sectionId}&variant=${variantId}`)
      .then(r => r.text())
      .then(html => {
        const doc = new DOMParser().parseFromString(html, "text/html");
        const newTarget = doc.querySelector('[li-render-custom="target"]');
        if (newTarget) {
          target.innerHTML = newTarget.innerHTML;
          initGallery();
        }
      });
  });
});
