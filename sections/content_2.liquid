                    <style>
/* ============================================
   Klaviyo Form RA6SEV &mdash; Vera Wang Custom Styling
   ============================================ */
/* Form wrapper */
.klaviyo-form-RA6SEV {
  background: transparent !important;
  font-family: "Gotham SSm A", "Gotham SSm B", "Gotham", sans-serif !important;
}
/* Inner form &mdash; single column grid */
.klaviyo-form-RA6SEV form,
.klaviyo-form-RA6SEV [data-testid="form-component"] {
  display: grid !important;
  grid-template-columns: 1fr !important;
  row-gap: 0px !important;
  width: 100% !important;
}
/* Fieldset reset */
.klaviyo-form-RA6SEV fieldset {
  border: none !important;
  padding: 0 !important;
  margin: 0 !important;
  width: 100% !important;
}
/* All go-class wrappers full width */
.klaviyo-form-RA6SEV [class*="go"] {
  width: 100% !important;
}
/* Input wrapper &mdash; fix align-self: flex-end which causes text shift on focus */
.klaviyo-form-RA6SEV .go3787345210.go3787345210.go3787345210,
.klaviyo-form-RA6SEV .klaviyo-textinput {
  align-self: stretch !important;
  height: auto !important;
  justify-content: center !important;
  overflow: visible !important;
}
/* Text inputs &mdash; match triple-class specificity to override Klaviyo */
.klaviyo-form-RA6SEV .go603421600.go603421600.go603421600 {
  background: transparent !important;
  border: none !important;
  border-bottom: 1px solid white !important;
  border-radius: 0 !important;
  color: white !important;
  font-family: "Gotham SSm A", "Gotham SSm B", "Gotham", sans-serif !important;
  font-size: 12px !important;
  font-weight: 500 !important;
  letter-spacing: 0.08em !important;
  line-height: 20px !important;
  padding: 0px 0 !important;
  height: auto !important;
  min-height: 38px !important;
  width: 100% !important;
  box-shadow: none !important;
  outline: none !important;
  overflow: visible !important;
  box-sizing: border-box !important;
}
.klaviyo-form-RA6SEV .go603421600.go603421600.go603421600:focus,
.klaviyo-form-RA6SEV .go603421600.go603421600.go603421600:focus-visible {
  outline: none !important;
  box-shadow: none !important;
  border-top: none !important;
  border-left: none !important;
  border-right: none !important;
  border-bottom: 1px solid white !important;
}
.klaviyo-form-RA6SEV .go603421600.go603421600.go603421600::placeholder {
  color: white !important;
  opacity: 1 !important;
  font-family: "Gotham SSm A", "Gotham SSm B", "Gotham", sans-serif !important;
  font-size: 12px !important;
  font-weight: 500 !important;
  letter-spacing: 0.08em !important;
  line-height: 20px !important;
}
/* Checkbox &mdash; hide native input */
.klaviyo-form-RA6SEV input[type="checkbox"] {
  position: absolute !important;
  opacity: 0 !important;
  width: 0 !important;
  height: 0 !important;
}
/* Checkbox label */
.klaviyo-form-RA6SEV input[type="checkbox"] + label,
.klaviyo-form-RA6SEV input[type="checkbox"] ~ label {
  display: flex !important;
  align-items: flex-start !important;
  gap: 12px !important;
  cursor: pointer !important;
  color: white !important;
  font-family: "Gotham SSm A", "Gotham SSm B", "Gotham", sans-serif !important;
  font-size: 10px !important;
  font-weight: 400 !important;
  letter-spacing: 0.05em !important;
  line-height: 1.5 !important;
}
/* Checkbox SVG icon &mdash; 16&times;16 square */
.klaviyo-form-RA6SEV input[type="checkbox"] + label svg,
.klaviyo-form-RA6SEV input[type="checkbox"] ~ label svg {
  width: 16px !important;
  height: 16px !important;
  min-width: 16px !important;
  min-height: 16px !important;
  flex-shrink: 0 !important;
  border: 1px solid white !important;
  border-radius: 0 !important;
  box-sizing: border-box !important;
  margin-top: 1px !important;
}
/* Checkbox unchecked &mdash; transparent fill */
.klaviyo-form-RA6SEV input[type="checkbox"] + label svg rect,
.klaviyo-form-RA6SEV input[type="checkbox"] ~ label svg rect {
  fill: transparent !important;
}
/* Checkbox checked &mdash; white fill */
.klaviyo-form-RA6SEV input[type="checkbox"]:checked + label svg rect,
.klaviyo-form-RA6SEV input[type="checkbox"]:checked ~ label svg rect {
  fill: white !important;
  fill-opacity: 1 !important;
}
/* Checkbox checked &mdash; black checkmark */
.klaviyo-form-RA6SEV input[type="checkbox"]:checked + label svg path,
.klaviyo-form-RA6SEV input[type="checkbox"]:checked ~ label svg path {
  stroke: black !important;
  stroke-opacity: 1 !important;
}
/* Privacy / consent text */
.klaviyo-form-RA6SEV [class*="consent"],
.klaviyo-form-RA6SEV [class*="privacy"],
.klaviyo-form-RA6SEV p {
  color: white !important;
  font-family: "Gotham SSm A", "Gotham SSm B", "Gotham", sans-serif !important;
  font-size: 10px !important;
  font-weight: 400 !important;
  letter-spacing: 0.05em !important;
}
.klaviyo-form-RA6SEV [class*="consent"] a,
.klaviyo-form-RA6SEV [class*="privacy"] a,
.klaviyo-form-RA6SEV p a {
  color: white !important;
  text-decoration: underline !important;
}
/* Privacy / consent text */
.klaviyo-form-RA6SEV [class*="consent"],
.klaviyo-form-RA6SEV [class*="privacy"],
.klaviyo-form-RA6SEV p {
  color: white !important;
  font-family: "Gotham SSm A", "Gotham SSm B", "Gotham", sans-serif !important;
  font-size: 10px !important;
  font-weight: 400 !important;
  letter-spacing: 0.05em !important;
}
/* Override Klaviyo's triple-class specificity on the privacy text div */
.klaviyo-form-RA6SEV .go2347003636.go2347003636.go2347003636 {
  color: white !important;
  font-family: "Gotham SSm A", "Gotham SSm B", "Gotham", sans-serif !important;
  font-size: 10px !important;
  font-weight: 400 !important;
  letter-spacing: 0.05em !important;
}
.klaviyo-form-RA6SEV [class*="consent"] a,
.klaviyo-form-RA6SEV [class*="privacy"] a,
.klaviyo-form-RA6SEV p a,
.klaviyo-form-RA6SEV .go2347003636.go2347003636.go2347003636 a {
  color: white !important;
  text-decoration: underline !important;
}
/* Button wrapper &mdash; full width */
.klaviyo-form-RA6SEV div:has(> button.klaviyo-form-button),
.klaviyo-form-RA6SEV div:has(> [data-testid="form-button"]) {
  width: 100% !important;
  display: flex !important;
  justify-content: stretch !important;
  margin-top: 24px !important;
}
/* Submit button */
.klaviyo-form-RA6SEV button,
.klaviyo-form-RA6SEV .klaviyo-form-button {
  width: 100% !important;
  background: transparent !important;
  border: 1px solid white !important;
  border-radius: 0 !important;
  color: white !important;
  font-family: "Gotham SSm A", "Gotham SSm B", "Gotham", sans-serif !important;
  font-size: 12px !important;
  font-weight: 600 !important;
  letter-spacing: 0.15em !important;
  text-transform: uppercase !important;
  padding: 0px 0px !important;
  cursor: pointer !important;
  display: block !important;
}
.klaviyo-form-RA6SEV button:hover {
  background: white !important;
  color: black !important;
}
/* Error messages */
.klaviyo-form-RA6SEV [class*="error"],
.klaviyo-form-RA6SEV [class*="Error"] {
  color: #ff6b6b !important;
  font-size: 10px !important;
  font-family: "Gotham SSm A", "Gotham SSm B", "Gotham", sans-serif !important;
}
</style>
