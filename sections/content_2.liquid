                    <style>
/* ===================================================================
   KLAVIYO FORM &mdash; TRANSPARENT BG + WHITE INK (MOBILE BEHAVIOUR UNCHANGED)
=================================================================== */
/* Easy theme tokens */
.klaviyo-form{
  --kl-ink: var(--base-color-neutral--white);
  --kl-ink-dim: rgba(255,255,255,0.75);
  --kl-hover-bg: var(--base-color-neutral--white);
  --kl-hover-ink: var(--base-color-neutral--black);
}
/* ===================================================================
   RESET KLAVIYO BASE STYLING
=================================================================== */
.klaviyo-form,
.klaviyo-form * {
  box-sizing: border-box;
  font-family: inherit !important;
  border-radius: 0 !important;
  color: inherit !important;
}
/* Nuke any white panel / wrapper backgrounds (including outer Klaviyo embed wrapper) */
[class^="klaviyo-form-"],
[class*=" klaviyo-form-"],
.klaviyo-form,
.klaviyo-form > div,
.klaviyo-form [data-testid="form-row"],
.klaviyo-form [data-testid="form-component"],
.klaviyo-form [data-testid="form-component"] > div,
.klaviyo-form [data-testid="form-component"] > div > div,
[class^="klaviyo-form-"] *,
[class*=" klaviyo-form-"] * {
  background: transparent !important;
  background-color: transparent !important;
}
/* Layout container */
.klaviyo-form {
  display: flex !important;
  flex-direction: column !important;
  width: 100% !important;
  gap: 0 !important;
  padding: 0 !important;
  color: var(--kl-ink) !important;
}
/* ===================================================================
   INPUT + LABEL STYLING
=================================================================== */
.klaviyo-form label {
  position: absolute !important;
  width: 1px !important;
  height: 1px !important;
  padding: 0 !important;
  margin: -1px !important;
  overflow: hidden !important;
  clip: rect(0, 0, 0, 0) !important;
  white-space: nowrap !important;
  border: 0 !important;
}
.klaviyo-form input[type="text"],
.klaviyo-form input[type="email"],
.klaviyo-form input[type="search"],
.klaviyo-form input[type="tel"] {
  width: 100%;
  padding: 0 0 0px 0 !important;
  margin: 0 !important;
  border: none !important;
  border-bottom: 1px solid var(--kl-ink) !important;
  background: transparent !important;
  text-transform: uppercase;
  font-size: var(--body-text);
  color: var(--kl-ink) !important;
}
.klaviyo-form input::placeholder {
  color: var(--kl-ink) !important;
  opacity: 0.75 !important;
  text-transform: uppercase;
  font-family: inherit !important;
  font-size: 0.75rem !important;
}
.klaviyo-form input:hover,
.klaviyo-form input:focus {
  outline: none !important;
  border-bottom: 1px solid var(--kl-ink) !important;
}
/* Extra override for Klaviyo &ldquo;kl-*&rdquo; inputs */
.klaviyo-form input[class*="kl-"]:hover,
.klaviyo-form input[class*="kl-"]:focus {
  border-color: var(--kl-ink) !important;
  border-bottom-color: var(--kl-ink) !important;
  color: var(--kl-ink) !important;
}
/* ===================================================================
   FORM ROW SPACING
=================================================================== */
.klaviyo-form [data-testid="form-row"] {
  display: flex !important;
  flex-direction: row !important;
  align-items: flex-end;
  /* margin: 0 0 1.2rem 0 !important; */
  gap: 0 !important;
  padding: 0 !important;
}
/* ===================================================================
   CITY + BUTTON ROW (SIDE-BY-SIDE WITH GAP)
=================================================================== */
.klaviyo-form [data-testid="form-row"]:last-of-type {
  display: grid !important;
  grid-template-columns: 1fr auto;
  column-gap: 0.75rem !important;
  margin-bottom: 0 !important;
}
.klaviyo-form [data-testid="form-row"]:last-of-type [data-testid="form-component"]:last-child {
  margin: 0 !important;
  padding: 0 !important;
}
.klaviyo-form [data-testid="form-row"]:last-of-type input {
  width: 100% !important;
}
/* ===================================================================
   BUTTON
=================================================================== */
.klaviyo-form button[type="button"] {
  padding: 0.3rem 2.5rem !important;
  border: 1px solid var(--kl-ink) !important;
  background: transparent !important;
  color: var(--kl-ink) !important;
  font-size: var(--body-text) !important;
  text-transform: uppercase;
  cursor: pointer;
  transition: background-color 200ms ease, color 200ms ease, border-color 200ms ease;
  margin: 0 !important;
  height: auto !important;
  min-height: 30px !important;
  margin-top: 20px !important;
}
.klaviyo-form button[type="button"]:hover {
  background: var(--kl-hover-bg) !important;
  color: var(--kl-hover-ink) !important;
  border-color: var(--kl-hover-bg) !important;
}
/* Hide the invisible submit */
.klaviyo-form input[type="submit"] {
  display: none !important;
}
/* ===================================================================
   RESPONSIVE ADJUSTMENTS (UNCHANGED)
=================================================================== */
@media screen and (max-width: 991px) {
  .klaviyo-form input {
    padding-top: 8px !important;
    padding-bottom: 8px !important;
  }
}
@media screen and (max-width: 479px) {
  .klaviyo-form input {
    padding-top: 4px !important;
    padding-bottom: 4px !important;
    font-size: 0.75rem !important;
  }
  .klaviyo-form button[type="button"] {
    padding: 0.2rem 2rem !important;
  }
  /* stack correctly on mobile if needed */
  .klaviyo-form [data-testid="form-row"]:last-of-type {
    grid-template-columns: 1fr;
    row-gap: 1rem;
  }
}
/* Remove ALL padding from all Klaviyo input wrappers */
.klaviyo-form [data-testid="form-component"],
.klaviyo-form [data-testid="form-row"] > div > div {
  padding: 0 !important;
  margin: 0 !important;
  background: transparent !important;
}
/* ===================================================================
   ERRORS / LIVE REGION &mdash; REMOVE WHITE BG + SET WHITE TEXT
   (This was causing the white rectangle)
=================================================================== */
.klaviyo-form [role="alert"],
.klaviyo-form [aria-live],
.klaviyo-form [data-testid*="error"],
.klaviyo-form [data-testid*="invalid"],
.klaviyo-form .klaviyo-form__error,
.klaviyo-form .klaviyo-form__error-message,
.klaviyo-form .kl-form-error,
.klaviyo-form .kl-error {
  background: transparent !important;
  background-color: transparent !important;
  color: var(--kl-ink) !important;
}
/* Children should also stay transparent/white */
.klaviyo-form [role="alert"] *,
.klaviyo-form [aria-live] *,
.klaviyo-form [data-testid*="error"] *,
.klaviyo-form [data-testid*="invalid"] *,
.klaviyo-form .klaviyo-form__error *,
.klaviyo-form .kl-form-error *,
.klaviyo-form .kl-error * {
  background: transparent !important;
  background-color: transparent !important;
  color: inherit !important;
}
/* Optional: make error copy stand out without a panel */
.klaviyo-form [role="alert"],
.klaviyo-form .kl-form-error,
.klaviyo-form .klaviyo-form__error-message {
  text-decoration: underline;
  text-underline-offset: 0.25em;
}
/* =========================================================
   DESKTOP: First + Last name side-by-side (Klaviyo inner wrapper)
========================================================= */
@media screen and (min-width: 992px) {
  .klaviyo-form > div {
    display: flex !important;
    flex-direction: row !important;
    flex-wrap: wrap !important;
    gap: 0rem 1.2rem !important;
    justify-content: flex-start !important;
    align-content: flex-start !important;
    min-height: 0 !important;
    background: transparent !important;
  }
  /* Default: every row takes full width */
  .klaviyo-form > div > [data-testid="form-row"] {
    flex: 0 0 100% !important;
    width: 100% !important;
  }
  /* First + Last rows are half width &mdash; ONLY when they contain inputs */
@media screen and (min-width: 992px) {
  .klaviyo-form > div > [data-testid="form-row"]:nth-of-type(1):has(input),
  .klaviyo-form > div > [data-testid="form-row"]:nth-of-type(2):has(input) {
    flex: 0 0 calc(50% - 0.6rem) !important;
    width: calc(50% - 0.6rem) !important;
  }
}
  /* Your existing :last-of-type rule sets grid; disable it for this form */
  .klaviyo-form > div > [data-testid="form-row"]:last-of-type {
    display: flex !important;
  }
}
/* =========================================================
   MOBILE OVERRIDE &mdash; ALWAYS BLACK TEXT + BLACK UNDERLINES
   (put this LAST so it wins)
========================================================= */
@media screen and (max-width: 991px) {
  /* Switch the tokens back to black on mobile */
  .klaviyo-form{
    --kl-ink: var(--base-color-neutral--black);
    --kl-ink-dim: rgba(0,0,0,0.75);
    --kl-hover-bg: var(--base-color-neutral--black);
    --kl-hover-ink: var(--base-color-neutral--white);
    color: var(--kl-ink) !important;
  }
  .klaviyo-form input[type="text"],
  .klaviyo-form input[type="email"],
  .klaviyo-form input[type="search"],
  .klaviyo-form input[type="tel"]{
    color: var(--kl-ink) !important;
    border-bottom-color: var(--kl-ink) !important;
    caret-color: var(--kl-ink) !important;
    -webkit-text-fill-color: var(--kl-ink) !important; /* iOS/Safari */
  }
  .klaviyo-form input::placeholder{
    color: var(--kl-ink) !important;
    opacity: 0.75 !important;
    -webkit-text-fill-color: var(--kl-ink) !important;
  }
  /* Keep underline black even on hover/focus */
  .klaviyo-form input:hover,
  .klaviyo-form input:focus,
  .klaviyo-form input[class*="kl-"]:hover,
  .klaviyo-form input[class*="kl-"]:focus{
    border-bottom-color: var(--kl-ink) !important;
    border-color: var(--kl-ink) !important;
    color: var(--kl-ink) !important;
    -webkit-text-fill-color: var(--kl-ink) !important;
  }
  /* Button stays black outline + black text on mobile */
  .klaviyo-form button[type="button"]{
    border-color: var(--kl-ink) !important;
    color: var(--kl-ink) !important;
  }
  .klaviyo-form button[type="button"]:hover{
    background: var(--kl-hover-bg) !important;
    color: var(--kl-hover-ink) !important;
    border-color: var(--kl-hover-bg) !important;
  }
  /* Autofill can force weird colors unless you override it */
  .klaviyo-form input:-webkit-autofill,
  .klaviyo-form input:-webkit-autofill:hover,
  .klaviyo-form input:-webkit-autofill:focus{
    -webkit-text-fill-color: var(--kl-ink) !important;
    box-shadow: 0 0 0px 1000px transparent inset !important;
    transition: background-color 9999s ease-out 0s;
  }
}
</style>
