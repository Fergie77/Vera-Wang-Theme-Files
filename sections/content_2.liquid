                    <div class="hide w-embed w-script">
                    <script>
  (function () {
  function fixKlaviyoInputScroll() {
    var form = document.querySelector('.klaviyo-form-RA6SEV');
    if (!form || form._scrollFixApplied) return;
    form._scrollFixApplied = true;
    var resetScroll = function (e) {
      var t = e.target;
      if (t && t.tagName === 'INPUT' && (t.type === 'text' || t.type === 'email' || t.type === 'tel')) {
        t.scrollTop = 0;
      }
    };
    form.addEventListener('scroll', resetScroll, true);
    form.addEventListener('select', resetScroll, true);
    form.addEventListener('mouseup', resetScroll, true);
  }
  // Run on load and after a short delay (Klaviyo renders asynchronously)
  document.addEventListener('DOMContentLoaded', function () {
    fixKlaviyoInputScroll();
    setTimeout(fixKlaviyoInputScroll, 2000);
  });
})();
</script>
