<div class="padding-global">
          <div class="container-large">
            <h2 class="sbv_heading heading-style-h2">
{{ section.settings.text_heading }}
</h2>
            <div class="spacer-medium"></div>
            <div class="more_component">
              <div class="more_list-wrapper w-dyn-list">
                <div class="more_list w-dyn-items" data-slider="more_list" data-slider-selector=".more_item" data-slider-origin="center" li-content-for-theme-blocks="" role="list" data-slider-breakpoint="small" data-slider-spacing="16" data-slider-per-view="1.2">
{% content_for 'blocks' %}
</div>
                <div class="hide w-dyn-empty">
                  <div>No items found.</div>
                </div>
              </div>
              <a href="{{ section.settings.url_cta_link }}" class="cta-text"> {{ section.settings.text_cta_text }} </a>
            </div>
          </div>
        </div> {% schema %} {
    "tag": "section",
    "name": "Styled By Vera",
    "class": "section_sbv",
    "blocks": [
        {
            "type": "block"
        },
        {
            "type": "@app"
        }
    ],
    "settings": [
        {
            "id": "text_heading",
            "type": "text",
            "label": "Heading",
            "default": "Styled By Vera Wang"
        },
        {
            "id": "text_cta_text",
            "type": "text",
            "label": "CTA Text",
            "default": "View All The Looks"
        },
        {
            "id": "url_cta_link",
            "type": "url",
            "label": "CTA Link"
        }
    ],
    "presets": [
        {
            "name": "Styled By Vera",
            "category": "Liquify",
            "blocks": [
                {
                    "type": "block"
                }
            ]
        }
    ]
} {% endschema %}