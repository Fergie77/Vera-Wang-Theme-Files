<div class="header_background-image-wrapper is-relative">
          <div class="header_background-image">{% if section.settings.image_image_left %}
{{ section.settings.image_image_left | image_url: width: 2000 | image_tag: loading: 'eager', class: 'header_background-image_item is-left' }}
{% else %}
 {{ 'detailed-apparel-1' | placeholder_svg_tag: 'header_background-image_item is-left' }} 
{% endif %}
            <div class="cta-text is-absolute" style="color:{{section.settings.text_color}}">
{{ section.settings.text_cta_text }}
</div>
            
          </div>
          <div class="header_background-image-right-wrapper">{% if section.settings.image_image_right %}
{{ section.settings.image_image_right | image_url: width: 1500 | image_tag: loading: 'eager', class: 'header_background-image_item is-right' }}
{% else %}
 {{ 'detailed-apparel-1' | placeholder_svg_tag: 'header_background-image_item is-right' }} 
{% endif %}
            <div class="header_card text-color-white">
              <div class="max-width-large">
                <div class="header_heading"> {{ section.settings.richtext_paragraph }} </div>
              </div>
            </div>
          </div>
          <a href="{{ section.settings.url_cta_link }}" class="header_link w-inline-block"> </a>
        </div> {% schema %} {
    "tag": "header",
    "name": "Image with Text",
    "class": "section_header-home",
    "settings": [
        {
            "id": "image_image_left",
            "type": "image_picker",
            "label": "Image Left"
        },
        {
            "id": "text_cta_text",
            "type": "text",
            "label": "CTA Text",
            "default": "Shop the collection"
        },
        {
            "type": "header",
            "content": "Links"
        },
        {
            "type": "color",
            "id": "text_color",
            "label": "Text Color",
            "default": "#000000"
        },
        {
            "id": "image_image_right",
            "type": "image_picker",
            "label": "Image Right"
        },
        {
            "id": "richtext_paragraph",
            "type": "richtext",
            "label": "Paragraph",
            "default": "<p>OUR COLLECTION OF AUTUMN WINTER 26 OUTERWEAR.<br\/>NOW AVAILABLE ONLINE AND IN RETAIL \u2028<\/p>"
        },
        {
            "id": "url_cta_link",
            "type": "url",
            "label": "CTA Link"
        }
    ],
    "presets": [
        {
            "name": "Image with Text",
            "category": "Liquify",
            "blocks": []
        }
    ]
} {% endschema %}