<script src="{{ 'li_custom.js' | asset_url }}" type="text/javascript"></script>
<div li-element="product-variant-container" class="product-item_component" x-data="handleVariant({{ product | json | escape }}, {{ product.options_by_name | json | escape }}, {{ product.selected_or_first_available_variant | json | escape }})" x-init="$nextTick(() => { activateVariants() })" @setbundleitem.window="updateBundleItem($event.detail.product, $event.detail.quantity)">
                        <div class="product-item_image-link">
                          <a li-object:href="product.url | append: '?variant=' | append: variant.id" href="{{ product.url | append: '?variant=' | append: variant.id }}" class="product-item_image-wrapper w-inline-block"><img li-object:alt="primary_image.alt" loading="lazy" li-object:src="primary_image | image_url: width: 450" src="{{ primary_image | image_url: width: 450 }}" alt="{{ primary_image.alt }}" class="product-item_image is-primary">
                            {% if secondary_image %}    <div li-if="secondary_image">
    <img li-object:alt="product.images[1].alt" loading="lazy" li-object:src="product.images[1] | image_url: width: 450" src="{{ product.images[1] | image_url: width: 450 }}" alt="{{ product.images[1].alt }}" class="product-item_image is-secondary">    </div>
{% endif %}
                          </a>
                          <div class="product-item_tag_list">
                            {% if product.selected_or_first_available_variant.available != true %}    <div li-if="product.selected_or_first_available_variant.available != true" class="product-item_tag">
    Not in Stock    </div>
{% endif %}
                            {% if product.compare_at_price_max > product.price %}    <div li-if="product.compare_at_price_max > product.price" class="product-item_tag is-red">
    Sale    </div>
{% endif %}
                          </div>
                          <div li-cloak="hide" class="hide w-embed">{% assign primary_image = nil %}
                            {% assign secondary_image = nil %}
                            {% for image in product.images %}
                            {% if image.alt contains colour_value %}
                            {% if primary_image == nil %}
                            {% assign primary_image = image %}
                            {% elsif secondary_image == nil %}
                            {% assign secondary_image = image %}
                            {% endif %}
                            {% endif %}
                            {% endfor %}
                            {% if primary_image == nil %}
                            {% assign primary_image = product.images[0] %}
                            {% endif %}</div>
                        </div>
                        <div class="spacer-xsmall"></div>
                        <a li-object:href="product.url | append: '?variant=' | append: variant.id" href="{{ product.url | append: '?variant=' | append: variant.id }}" class="product-item_text-link w-inline-block">
                          <div class="product-item_details-layout">
                            <div class="product-item_left">
                              <h3 li-object="product.title" class="product-item_title">{{ product.title }}</h3>
                            </div>
                            <div class="product-item_subtitle">
                              {% if product.compare_at_price_max > product.price %}    <div li-if="product.compare_at_price_max > product.price">
    
                                <p li-object="product.compare_at_price | money" class="text-style-strikethrough text-style-muted">{{ product.compare_at_price | money }}</p>
                                  </div>
{% endif %}
                              <p li-object="product.price | money">{{ product.price | money }}</p>
                            </div>
                          </div>
                          <div class="product-item_variants-wrapper">
                            {% if product.has_only_default_variant == true %}    <p li-if="product.has_only_default_variant == true" class="product-item_subtitle text-weight-normal">
    1 Colour    </p>
{% endif %}
                            {% if product.has_only_default_variant != true %}    <div li-if="product.has_only_default_variant != true" class="product-header_option-list">
    
                              <div li-cloak="hide" class="w-embed">{% assign color_index = nil %}
                                {% for option in product.options %}
                                {% if option | downcase == 'color' %}
                                {% assign color_index = forloop.index0 %}
                                {% endif %}
                                {% endfor %}
                                {% assign seen_colours = '' %}</div>
                              <div class="product-header_option">
                                {% for variant in product.variants %}    <div li-for="variant in product.variants">
                                    
                                  
                            {% colour_value = variant.options[color_index] %}
                            
                                  
                            {% unless seen_colours contains colour_value %}    <div li-unless="seen_colours contains colour_value">
    
                                    {% assign seen_colours = seen_colours | append: colour_value | append: '|' %}
                                    <div class="product-header_radio-list">
                                      <div class="product-header_radio-layout">
                                        <div class="product-item_variant-colour" style="background: {{ colour_value }}"></div>
                                      </div>
                                    </div>
                                      </div>
{% endunless %}
                            
                                
                        </div>
{% endfor %}
                              </div>
                                </div>
{% endif %}
                          </div>
                        </a>
                      </div>
