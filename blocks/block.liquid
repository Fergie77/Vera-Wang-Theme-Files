<div li-block="Block" role="listitem" class="more_item w-dyn-item" {{ block.shopify_attributes }}>
                    
                    
                    <a href="{{ block.settings.url_link }}" class="more_image-link w-inline-block"> <div class="more_image-wrapper">{% if block.settings.image_image %} {{ block.settings.image_image | image_url: width: 450 | image_tag: data-id: 'test', loading: variable, class: 'more_image' }} {% else %} {{ 'detailed-apparel-1' | placeholder_svg_tag: 'more_image' }} {% endif %}</div> </a>
                    
                  
                </div> {% schema %} {
    "name": "Block",
    "settings": [
        {
            "id": "url_link",
            "type": "url",
            "label": "Link"
        },
        {
            "id": "image_image",
            "type": "image_picker",
            "label": "Image"
        }
    ],
    "presets": [
        {
            "name": "Block",
            "blocks": []
        }
    ],
    "tag": null
} {% endschema %}